import { NNA_API_URL, DERIVACION_API_URL, INTERVENCION_API_URL, AUTH_API_URL, EXPEDIENTE_API_URL } from '../../../config/api';
import { useState, useEffect } from 'react';
import { Printer, Save, Plus, Edit2, Trash2, X, ArrowLeft, User, Users, GraduationCap, HeartPulse, Target } from 'lucide-react';
import { UbigeoSelectorSimple } from './UbigeoSelectorSimple';

interface Formato4SocialProps {
    nna: any;
    caso?: any;
    initialData?: any; // Para modo edición
    onClose?: () => void; // Para volver a la lista
    onSuccess?: () => void; // Para refrescar la lista
}

interface FamilyMember {
    primerApellido: string;
    segundoApellido: string;
    nombres: string;
    parentesco: string;
    edad: string;
    sexo: string;
    gradoInstruccion: string;
    ocupacion: string;
    estadoCivil?: string;
}

interface Need {
    categoria: string;
    descripcion: string;
    faseI: string;
    faseII: string;
    faseIII: string;
}

export const Formato4Social = ({ nna, caso, initialData, onClose, onSuccess }: Formato4SocialProps) => {
    // Modal state - Familiares
    const [showFamilyModal, setShowFamilyModal] = useState(false);
    const [editingFamilyIndex, setEditingFamilyIndex] = useState<number | null>(null);
    const [currentFamily, setCurrentFamily] = useState<FamilyMember>({
        primerApellido: '',
        segundoApellido: '',
        nombres: '',
        parentesco: '',
        edad: '',
        sexo: '',
        gradoInstruccion: '',
        ocupacion: '',
        estadoCivil: ''
    });

    // Modal state - Necesidades
    const [showNeedModal, setShowNeedModal] = useState(false);
    const [editingNeedIndex, setEditingNeedIndex] = useState<number | null>(null);
    const [currentNeed, setCurrentNeed] = useState<Need>({
        categoria: '',
        descripcion: '',
        faseI: '',
        faseII: '',
        faseIII: ''
    });

    const [activeTab, setActiveTab] = useState<'GENERAL' | 'FAMILIA' | 'EDUCACION' | 'SALUD' | 'NECESIDADES'>('GENERAL');

    const [formData, setFormData] = useState({
        // Sección I: Datos Generales (Adicionales) - Prellenado desde Ficha Inscripción (nna)
        fechaInicioFicha: '',
        fechaFinFicha: '',
        lugarNacimientoDepartamento: nna?.departamentoNacimiento || '',
        lugarNacimientoProvincia: nna?.provinciaNacimiento || '',
        lugarNacimientoDistrito: nna?.distritoNacimiento || '',
        direccionActual: nna?.direccionDomicilio || '',
        domicilioDepartamento: nna?.departamentoDomicilio || '',
        domicilioProvincia: nna?.provinciaDomicilio || '',
        domicilioDistrito: nna?.distritoDomicilio || '',
        sexo: nna?.sexo || '',
        seguroSalud: {
            sis: nna?.afiliadoSIS === 'SI',
            essalud: nna?.tipoSeguro === 'ESSALUD',
            otro: false,
            detalleOtro: ''
        },
        noTieneDNI: !nna?.numeroDoc,

        // Sección II: Situación de Calle
        tiempoEnCalle: caso?.tiempoEnCalle || '',
        puntoConcentracion: caso?.zonaIntervencion || '',
        actividadEconomica: caso?.actividadRealizada || '',

        // Detalle Estructurado Sección II (Según Imagen)
        situacionCalleDetalle: {
            perfil: { trabajoInfantil: false, mendicidad: false, vidaEnCalle: false, transito: false, convivencia: false },
            tiempo: { cantidad: '', unidad: 'MESES' },
            explotacionSexual: null as boolean | null,
            horarios: { manana: false, tarde: false, noche: false },
            frecuencia: { diario: false, interdiario: false, finesSemana: false, temporadas: false },
            acompanamiento: { solo: false, acompanado: false, acompanadoFamiliar: false, quien: '' },
            motivo: '',
            modalidadTrabajo: { puestoFijo: false, ambulante: false, recorre: false },
            ingresoSemanal: '',
            actividad: '',
            lugar: '',
            obligado: { si: false, no: false, quien: '' },
            usoDinero: { gastosFamiliares: false, gastosPropios: false, entregaOtro: false, detalleOtro: '' },
            escapoCasa: { si: false, no: false, veces: '' },
            consumo: { si: false, no: false, tipo: '', frecuencia: '', tiempo: '', unidadTiempo: '' }
        },

        // Sección III: Tutor
        tutorNombre: nna?.nombreTutor || '',
        tutorDNI: nna?.numeroDocTutor || '',
        tutorDireccion: '',
        tutorTelefono: '',
        tutorGradoInstruccion: '',
        tutorFechaNacimiento: '',
        tutorParentesco: '',
        tutorDiscapacidad: '',
        tutorConadis: '',
        tutorEstadoCivil: '',
        tutorOcupacion: '',
        tutorIngreso: '',
        tutorConsumoDrogas: '',
        tutorRecibeApoyo: '',
        tutorDeseaDemanda: '',

        // Sección IV: Familia - Prellenado desde nna.familiares si existen
        familiares: Array.isArray(nna?.familiares) ? nna.familiares.map((f: any) => ({
            primerApellido: f.apellidoPaterno || '',
            segundoApellido: f.apellidoMaterno || '',
            nombres: f.nombres || '',
            parentesco: f.parentesco || '',
            edad: f.edad?.toString() || '',
            sexo: f.sexo || '',
            gradoInstruccion: f.gradoInstruccion || '',
            ocupacion: f.ocupacion || '',
            estadoCivil: f.estadoCivil || ''
        })) : [] as FamilyMember[],

        dinamicaFamiliar: {
            contacto: '',
            frecuencia: '',
            rolProtector: '',
            rolProveedor: ''
        },
        // Sección V: Vivienda
        materialVivienda: '',
        numeroAmbientes: '',
        propiedadVivienda: '',
        serviciosBasicos: { agua: false, luz: false, desague: false, otros: false },
        viviendaSisfoh: '',
        duermeCama: '',
        duermeConQuien: '',
        duermeSoloAcompanado: '',
        higieneDomicilio: '',
        tiempoAlbergue: '',
        tieneAntecedenteAlbergue: nna?.tieneAntecedenteAlbergue || false,
        detalleAntecedenteAlbergue: nna?.detalleAntecedenteAlbergue || '',

        // Sección VI: Educación
        presentaAtraso: false,
        tiempoAtraso: '',
        motivoAtraso: '',

        // Sección VI: Educación (Campos Adicionales)
        eduEstudia: nna?.estudiaActualmente ? 'SI' : 'NO',
        eduModalidad: '',
        eduTurno: '',
        eduTipoIE: '',
        eduNombreIE: nna?.institucionEducativa || '',
        eduGrado: nna?.gradoEstudio || '',
        eduNivel: nna?.nivelEducativo || '',
        eduAtrasoMotivoDetalle: '', // Para "REPITIO", "DESERTO", "NO ESTUDIO" radio

        eduProblemasAprendizaje: '', // SI/NO
        eduExpulsado: '', // SI/NO
        eduExpulsadoVeces: '',
        eduProbConductuales: '', // SI/NO
        eduProbConductualesIntensidad: '', // LEVE, MODERADO, SEVERO
        eduFaltasTardanzas: '', // SI/NO
        eduDuermeClase: '', // SI/NO
        eduBullying: '', // SI/NO
        eduPadreConversa: '',

        // Sección VII: Salud, Alimentación, Higiene
        saludProblemas: { piel: false, desnutricion: false, respiratorios: false, its: false, otros: false },
        saludEnfermedadCronica: '', // SI, NO
        saludRecibeTratamiento: '', // SI, NO
        saludDiscapacidad: nna?.conadis_tiene === 'SI' ? 'SI' : 'NO', // Datos precargados si existen
        saludCarnetConadis: nna?.conadis_carnet || '',
        saludTipoDiscapacidad: '', // MENTAL, SENSORIAL, FISICA, INTELECTUAL
        saludLugarTratamiento: '', // HOSPITAL, CENTRO DE SALUD, OTRO

        psicoIndicadores: '', // SI, NO
        psicoTipoIndicador: { autoestima: false, depresion: false, ansiedad: false, impulsividad: false },
        psicoDetalles: '',

        adiccionTratamiento: '', // SI, NO (Si presenta adicción, recibe tratamiento?)
        adiccionDetalles: '',

        condicionGestando: '', // SI, NO
        condicionPadreAdolescente: '', // SI, NO
        condicionAborto: '', // SI, NO
        condicionAbusoSexual: '', // SI, NO

        alimTresComidas: '', // SI, NO
        alimBienAlimentado: '', // SI, NO
        alimLugar: '', // CALLE, HOGAR, OTRO
        alimQuienAsume: '', // USUARIO, PADRE/TUTOR, INSTITUCION, OTROS

        higieneAseaDiario: '', // SI, NO, A VECES
        higieneRopaLimpia: '',
        higieneNormasComer: '',
        higieneCabelloUnas: '',

        violenciaPadres: '', // SI, NO
        violenciaTipo: { fisica: false, psicologica: false },
        violenciaQuien: '',

        // Sección VIII: Recreación e Intereses
        recreacionTiempoJuego: '', // SI, NO
        recreacionVecesSemana: '',
        recreacionLugar: '', // CALLE/PARQUE, CASA, OTRO
        recreacionInteresDeporte: '',
        recreacionInteresArte: '',
        recreacionActividadFamilia: '', // SI, NO
        recreacionParticipaInstitucion: '', // SI, NO
        recreacionTipoInstitucion: '', // IGLESIA, SOCIAL/CULTURAL, DEPORTIVO, OTROS
        recreacionInstitucionDetalle: '', // SI/NO
        problemasAprendizaje: false,
        problemasConducta: false,
        expulsado: false,
        vecesExpulsado: '',

        // Sección VII: Salud
        enfermedadCronica: false,
        detalleEnfermedadCronica: '',
        problemaPsicologico: false,
        detalleProblemaPsicologico: '',
        consumeSustancias: false,
        tipoSustancias: '',
        recibeTresAlimentos: false,
        higieneAdecuada: false,

        // Sección VIII: Recreación
        tiempoParaJugar: false,
        vecesJuegaSemana: '',
        lugarJuego: '',
        participaInstitucion: false,
        tipoInstitucion: '',
        interesesDeportivos: false,
        interesesArtisticos: false,
        actividadesFamilia: false,

        // Sección IX: Necesidades (ahora dinámico)
        necesidades: [] as Need[]
    });

    // Cargar datos iniciales si estamos en modo edición
    useEffect(() => {
        if (initialData) {
            setFormData(prev => ({
                ...prev,
                // Sección I
                fechaInicioFicha: initialData.fechaInicioFicha || prev.fechaInicioFicha,
                fechaFinFicha: initialData.fechaFinFicha || prev.fechaFinFicha,
                lugarNacimientoDepartamento: initialData.lugarNacimientoDepartamento || prev.lugarNacimientoDepartamento,
                lugarNacimientoProvincia: initialData.lugarNacimientoProvincia || prev.lugarNacimientoProvincia,
                lugarNacimientoDistrito: initialData.lugarNacimientoDistrito || prev.lugarNacimientoDistrito,
                direccionActual: initialData.direccionActual || prev.direccionActual,
                domicilioDepartamento: initialData.domicilioDepartamento || prev.domicilioDepartamento,
                domicilioProvincia: initialData.domicilioProvincia || prev.domicilioProvincia,
                domicilioDistrito: initialData.domicilioDistrito || prev.domicilioDistrito,
                sexo: initialData.sexo || prev.sexo,
                seguroSalud: initialData.seguroSalud || prev.seguroSalud, // Asegurar que backend devuelva esto formateado o ajustarlo

                // Sección II (Cargar Detalle si existe, o defaults)
                tiempoEnCalle: initialData.tiempoEnCalle || prev.tiempoEnCalle,
                // Si guardamos el detalle como JSON string en 'situacionCalle', intentamos parsearlo
                situacionCalleDetalle: initialData.situacionCalle && initialData.situacionCalle.startsWith('{')
                    ? JSON.parse(initialData.situacionCalle)
                    : prev.situacionCalleDetalle,

                puntoConcentracion: (!initialData.situacionCalle?.startsWith('{') ? initialData.situacionCalle : '') || prev.puntoConcentracion,
                actividadEconomica: initialData.actividadCalle || prev.actividadEconomica,
                familiares: initialData.familiares || [],
                materialVivienda: initialData.materialParedes || prev.materialVivienda,
                serviciosBasicos: initialData.serviciosBasicos || prev.serviciosBasicos,
                vecesExpulsado: initialData.vecesExpulsado || prev.vecesExpulsado,
                enfermedadCronica: initialData.enfermedadCronica || false,
                detalleEnfermedadCronica: initialData.detalleEnfermedadCronica || '',
                problemaPsicologico: initialData.problemaPsicologico || false,
                detalleProblemaPsicologico: initialData.detalleProblemaPsicologico || '',
                consumeSustancias: initialData.consumeSustancias || false,
                tipoSustancias: initialData.tipoSustancias || '',
                recibeTresAlimentos: initialData.recibeTresAlimentos || false,
                higieneAdecuada: initialData.higieneAdecuada || false,
                tiempoParaJugar: initialData.tiempoParaJugar || false,
                vecesJuegaSemana: initialData.vecesJuegaSemana || '',
                lugarJuego: initialData.lugarJuego || '',
                participaInstitucion: initialData.participaInstitucion || false,
                tipoInstitucion: initialData.tipoInstitucion || '',
                interesesDeportivos: initialData.interesesDeportivos || false,
                interesesArtisticos: initialData.interesesArtisticos || false,
                actividadesFamilia: initialData.actividadesFamilia || false,
                necesidades: initialData.necesidades || [],
                // Mapear otros campos según sea necesario...
            }));
        }
    }, [initialData]);

    const handleSave = async () => {
        try {
            const token = localStorage.getItem('token');
            // ... (token logic) ...

            // Obtener usuario del store
            const userStr = localStorage.getItem('user');
            const user = userStr ? JSON.parse(userStr) : null;

            const payload = {
                responsable_id: user?.id,

                // Datos Generales (Nuevos campos)
                fechaInicioFicha: formData.fechaInicioFicha,
                fechaFinFicha: formData.fechaFinFicha,
                lugarNacimientoDepartamento: formData.lugarNacimientoDepartamento,
                lugarNacimientoProvincia: formData.lugarNacimientoProvincia,
                lugarNacimientoDistrito: formData.lugarNacimientoDistrito,
                direccionActual: formData.direccionActual,
                domicilioDepartamento: formData.domicilioDepartamento,
                domicilioProvincia: formData.domicilioProvincia,
                domicilioDistrito: formData.domicilioDistrito,
                sexo: formData.sexo,
                seguroSalud: formData.seguroSalud,

                // Situación de Calle
                tiempoEnCalle: formData.situacionCalleDetalle.tiempo.cantidad + ' ' + formData.situacionCalleDetalle.tiempo.unidad,
                // Guardamos TODO el detalle estructurado como JSON String en 'situacionCalle'
                situacionCalle: JSON.stringify(formData.situacionCalleDetalle),
                actividadCalle: formData.situacionCalleDetalle.actividad,
                motivoIngreso: formData.situacionCalleDetalle.motivo,
                lugarPernota: formData.situacionCalleDetalle.lugar,

                // Mapear campos duplicados de Salud que ahora están en Sección II
                consumeSustancias: formData.situacionCalleDetalle.consumo.si,
                tipoSustancias: formData.situacionCalleDetalle.consumo.tipo,

                // Tutor
                nombreTutor: formData.tutorNombre,
                dniTutor: formData.tutorDNI,
                direccionTutor: formData.tutorDireccion,
                telefonoTutor: formData.tutorTelefono,

                // Familia
                familiares: formData.familiares,

                // Vivienda
                materialParedes: formData.materialVivienda,
                serviciosBasicos: formData.serviciosBasicos,

                // Escolaridad
                vecesExpulsado: formData.vecesExpulsado,

                // Salud
                enfermedadCronica: formData.enfermedadCronica,
                detalleEnfermedadCronica: formData.detalleEnfermedadCronica,
                problemaPsicologico: formData.problemaPsicologico,
                detalleProblemaPsicologico: formData.detalleProblemaPsicologico,

                recibeTresAlimentos: formData.recibeTresAlimentos,
                higieneAdecuada: formData.higieneAdecuada,

                // Recreación
                tiempoParaJugar: formData.tiempoParaJugar,
                vecesJuegaSemana: formData.vecesJuegaSemana,
                lugarJuego: formData.lugarJuego,
                participaInstitucion: formData.participaInstitucion,
                tipoInstitucion: formData.tipoInstitucion,
                interesesDeportivos: formData.interesesDeportivos,
                interesesArtisticos: formData.interesesArtisticos,
                actividadesFamilia: formData.actividadesFamilia,

                // Necesidades
                necesidades: formData.necesidades,

                estado: 'COMPLETO'
            };

            const url = initialData?.id
                ? `${INTERVENCION_API_URL}/diagnostico/${initialData.id}`
                : `${NNA_API_URL}/nna/${nna.id}/diagnosticos`;

            const method = initialData?.id ? 'PUT' : 'POST';

            const response = await fetch(url, {
                method: method,
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify(payload)
            });

            if (!response.ok) {
                throw new Error('Error al guardar diagnóstico');
            }

            const result = await response.json();
            console.log('Diagnóstico guardado exitosamente:', result);
            alert('✅ Diagnóstico Social guardado correctamente');

            if (onSuccess) onSuccess();
            if (onClose) onClose();

        } catch (error) {
            console.error('Error al guardar:', error);
            alert('❌ Error al guardar el diagnóstico. Intenta nuevamente.');
        }
    };

    // Handlers para modal de familiares
    const handleAddFamily = () => {
        setCurrentFamily({
            primerApellido: '', segundoApellido: '', nombres: '', parentesco: '', edad: '', sexo: '', gradoInstruccion: '', ocupacion: '',
            estadoCivil: ''
        });
        setEditingFamilyIndex(null);
        setShowFamilyModal(true);
    };

    const handleEditFamily = (index: number) => {
        setCurrentFamily(formData.familiares[index]);
        setEditingFamilyIndex(index);
        setShowFamilyModal(true);
    };

    const handleDeleteFamily = (index: number) => {
        setFormData({
            ...formData,
            familiares: formData.familiares.filter((_, i) => i !== index)
        });
    };

    const handleSaveFamily = () => {
        if (editingFamilyIndex !== null) {
            // Editar familiar existente
            const updatedFamiliares = [...formData.familiares];
            updatedFamiliares[editingFamilyIndex] = currentFamily;
            setFormData({ ...formData, familiares: updatedFamiliares });
        } else {
            // Agregar nuevo familiar
            setFormData({ ...formData, familiares: [...formData.familiares, currentFamily] });
        }
        setShowFamilyModal(false);
    };

    // Handlers para modal de necesidades
    const handleAddNeed = () => {
        setCurrentNeed({ categoria: '', descripcion: '', faseI: '', faseII: '', faseIII: '' });
        setEditingNeedIndex(null);
        setShowNeedModal(true);
    };

    const handleEditNeed = (index: number) => {
        setCurrentNeed(formData.necesidades[index]);
        setEditingNeedIndex(index);
        setShowNeedModal(true);
    };

    const handleDeleteNeed = (index: number) => {
        setFormData({
            ...formData,
            necesidades: formData.necesidades.filter((_, i) => i !== index)
        });
    };

    const handleSaveNeed = () => {
        if (editingNeedIndex !== null) {
            // Editar necesidad existente
            const updatedNecesidades = [...formData.necesidades];
            updatedNecesidades[editingNeedIndex] = currentNeed;
            setFormData({ ...formData, necesidades: updatedNecesidades });
        } else {
            // Agregar nueva necesidad
            setFormData({ ...formData, necesidades: [...formData.necesidades, currentNeed] });
        }
        setShowNeedModal(false);
    };


    // Estilos inline para impresión (iguales al Formato3Print)
    const tableStyle = { borderCollapse: 'collapse', width: '100%', fontSize: '10px', fontFamily: 'Arial, sans-serif' } as const;
    const tdStyle = { border: '1px solid black', padding: '3px 4px', verticalAlign: 'middle' } as const;
    const thStyle = { border: '1px solid black', backgroundColor: '#f3f4f6', padding: '3px', textAlign: 'center', fontWeight: 'bold' } as const;
    const labelStyle = { fontSize: '8px', textTransform: 'uppercase', color: '#444', display: 'block', marginBottom: '1px' } as const;
    const valueStyle = { fontWeight: 'bold', fontSize: '11px', textTransform: 'uppercase' } as const;
    const sectionTitle = {
        backgroundColor: '#e5e7eb',
        color: '#000',
        padding: '4px',
        fontWeight: 'bold',
        textTransform: 'uppercase',
        fontSize: '11px',
        marginTop: '8px',
        border: '1px solid black',
        borderBottom: 'none'
    } as const;

    const formatDate = (dateStr: string) => dateStr ? new Date(dateStr).toLocaleDateString() : '---';

    return (
        <div className="bg-gray-100 print:bg-white min-h-screen p-6 print:p-0">

            {/* ===== VISTA WEB (INTERACTIVA) - Solo visible en pantalla ===== */}
            <div className="max-w-7xl mx-auto print:hidden">

                {/* Header con acciones */}
                <div className="bg-white border-b border-gray-200 px-6 py-4 rounded-t-xl shadow-sm">
                    <div className="flex items-center justify-between">
                        <div>
                            <h1 className="text-2xl font-black text-gray-900 uppercase">FICHA DE DIAGNÓSTICO SOCIAL</h1>
                            <p className="text-sm text-gray-500 mt-1">Completa la evaluación social del NNA</p>
                        </div>
                        <div className="flex gap-3">
                            <button
                                onClick={handleSave}
                                className="flex items-center gap-2 bg-indigo-600 text-white px-6 py-2.5 rounded-lg shadow-lg hover:bg-indigo-700 transition-all font-bold"
                            >
                                <Save size={20} /> Guardar
                            </button>
                            <button
                                onClick={() => window.print()}
                                className="flex items-center gap-2 bg-blue-600 text-white px-6 py-2.5 rounded-lg shadow-lg hover:bg-blue-700 transition-all font-bold"
                            >
                                <Printer size={20} /> Imprimir
                            </button>
                        </div>
                    </div>
                </div>


                {/* TABS DE NAVEGACIÓN */}
                <div className="bg-white px-6 pt-4 border-x border-gray-200">
                    <div className="flex overflow-x-auto gap-2 pb-0 mb-0 no-scrollbar">
                        {[
                            { id: 'GENERAL', label: 'I-III. GENERAL / CALLE', icon: User },
                            { id: 'FAMILIA', label: 'IV-V. FAMILIA / VIVIENDA', icon: Users },
                            { id: 'EDUCACION', label: 'VI. EDUCACIÓN', icon: GraduationCap },
                            { id: 'SALUD', label: 'VII-VIII. SALUD / RECREACIÓN', icon: HeartPulse },
                            { id: 'NECESIDADES', label: 'VIII. NECESIDADES', icon: Target }
                        ].map((tab) => (
                            <button
                                key={tab.id}
                                onClick={() => setActiveTab(tab.id as any)}
                                className={`
                                    flex items-center gap-2 px-6 py-4 border-b-4 text-sm font-black uppercase tracking-wide transition-all whitespace-nowrap
                                    ${activeTab === tab.id
                                        ? 'border-blue-600 text-blue-700 bg-blue-50/50'
                                        : 'border-transparent text-gray-400 hover:text-gray-600 hover:bg-gray-50'}
                                `}
                            >
                                <tab.icon size={18} className={activeTab === tab.id ? 'text-blue-600' : 'text-gray-400'} />
                                {tab.label}
                            </button>
                        ))}
                    </div>
                </div>

                {/* Contenido del formulario */}
                <div className="bg-white rounded-b-xl shadow-sm p-8 space-y-8 border-t border-gray-100">

                    {/* I. DATOS GENERALES */}
                    <div className={`bg-white rounded-xl border border-gray-200 overflow-hidden ${activeTab === 'GENERAL' ? '' : 'hidden'}`}>
                        <div className="bg-gray-50 border-b border-gray-200 px-4 py-2">
                            <h2 className="text-sm font-black text-gray-900 uppercase">
                                I. DATOS GENERALES
                            </h2>
                        </div>
                        <div className="p-4 grid grid-cols-12 gap-x-4 gap-y-4 text-xs">

                            {/* Nombres y Apellidos */}
                            <div className="col-span-12 md:col-span-6 border-b pb-2 md:border-b-0">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase">Nombres y Apellidos</label>
                                <p className="font-bold text-gray-900 text-sm">{nna?.nombres} {nna?.apellidoPaterno} {nna?.apellidoMaterno}</p>
                            </div>

                            {/* DNI */}
                            <div className="col-span-12 md:col-span-6">
                                <div className="flex items-center gap-4">
                                    <div className="flex-1">
                                        <label className="block text-[10px] font-bold text-gray-400 uppercase">DNI</label>
                                        <p className="font-bold text-gray-900 text-sm">{nna?.numeroDoc || '---'}</p>
                                    </div>
                                    <div className="flex items-center gap-2">
                                        <input
                                            type="checkbox"
                                            className="w-4 h-4 rounded text-blue-600"
                                            checked={formData.noTieneDNI}
                                            readOnly
                                        />
                                        <label className="font-bold text-gray-500 uppercase text-[10px]">No cuenta con DNI</label>
                                    </div>
                                </div>
                            </div>

                            <hr className="col-span-12 border-gray-100" />

                            {/* Lugar de Nacimiento */}
                            <div className="col-span-12 md:col-span-8 bg-gray-50/50 p-2 rounded-lg border border-gray-100">
                                <label className="block text-[10px] font-bold text-indigo-800 uppercase mb-2 border-b border-gray-200 pb-1">Lugar de Nacimiento</label>
                                <UbigeoSelectorSimple
                                    departamento={formData.lugarNacimientoDepartamento}
                                    provincia={formData.lugarNacimientoProvincia}
                                    distrito={formData.lugarNacimientoDistrito}
                                    onChange={(field, value) => {
                                        if (field === 'departamento') setFormData(prev => ({ ...prev, lugarNacimientoDepartamento: value, lugarNacimientoProvincia: '', lugarNacimientoDistrito: '' }));
                                        else if (field === 'provincia') setFormData(prev => ({ ...prev, lugarNacimientoProvincia: value, lugarNacimientoDistrito: '' }));
                                        else if (field === 'distrito') setFormData(prev => ({ ...prev, lugarNacimientoDistrito: value }));
                                    }}
                                />
                            </div>

                            {/* Fecha Nacimiento */}
                            <div className="col-span-6 md:col-span-2">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Fecha Nacimiento</label>
                                <div className="font-bold text-gray-900 bg-gray-50 px-3 py-1.5 rounded border border-gray-100 text-center">
                                    {formatDate(nna?.fechaNacimiento)}
                                </div>
                            </div>

                            {/* Sexo */}
                            <div className="col-span-6 md:col-span-2">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Sexo</label>
                                <select
                                    className="w-full px-2 py-1.5 border border-gray-200 rounded text-xs"
                                    value={formData.sexo}
                                    onChange={(e) => setFormData({ ...formData, sexo: e.target.value })}
                                >
                                    <option value="">--</option>
                                    <option value="M">M</option>
                                    <option value="F">F</option>
                                </select>
                            </div>

                            {/* Seguro Salud */}
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Seguro Salud (X)</label>
                                <div className="flex gap-3 items-center mt-2">
                                    <label className="flex items-center gap-1">
                                        <input
                                            type="checkbox"
                                            className="w-4 h-4 text-blue-600 rounded"
                                            checked={formData.seguroSalud.sis}
                                            onChange={(e) => setFormData({ ...formData, seguroSalud: { ...formData.seguroSalud, sis: e.target.checked } })}
                                        />
                                        <span className="text-[10px] font-bold">SIS</span>
                                    </label>
                                    <label className="flex items-center gap-1">
                                        <input
                                            type="checkbox"
                                            className="w-4 h-4 text-blue-600 rounded"
                                            checked={formData.seguroSalud.essalud}
                                            onChange={(e) => setFormData({ ...formData, seguroSalud: { ...formData.seguroSalud, essalud: e.target.checked } })}
                                        />
                                        <span className="text-[10px] font-bold">ESSALUD</span>
                                    </label>
                                    <label className="flex items-center gap-1">
                                        <input
                                            type="checkbox"
                                            className="w-4 h-4 text-blue-600 rounded"
                                            checked={formData.seguroSalud.otro}
                                            onChange={(e) => setFormData({ ...formData, seguroSalud: { ...formData.seguroSalud, otro: e.target.checked } })}
                                        />
                                        <span className="text-[10px] font-bold">OTRO</span>
                                    </label>
                                </div>
                            </div>

                            {/* Dirección Actual */}
                            <div className="col-span-12 bg-blue-50/30 p-3 rounded-xl border border-blue-100 space-y-3">
                                <h3 className="text-[10px] font-black text-blue-800 uppercase border-b border-blue-100 pb-1">Domicilio Actual</h3>

                                <UbigeoSelectorSimple
                                    departamento={formData.domicilioDepartamento}
                                    provincia={formData.domicilioProvincia}
                                    distrito={formData.domicilioDistrito}
                                    onChange={(field, value) => {
                                        if (field === 'departamento') setFormData(prev => ({ ...prev, domicilioDepartamento: value, domicilioProvincia: '', domicilioDistrito: '' }));
                                        else if (field === 'provincia') setFormData(prev => ({ ...prev, domicilioProvincia: value, domicilioDistrito: '' }));
                                        else if (field === 'distrito') setFormData(prev => ({ ...prev, domicilioDistrito: value }));
                                    }}
                                />

                                <div>
                                    <label className="block text-[10px] font-bold text-gray-500 uppercase mb-1">Dirección (Av/Jr/Calle/Psje, Nro, Mz, Lte)</label>
                                    <input
                                        type="text"
                                        className="w-full px-3 py-2 border border-blue-200 rounded-lg text-xs bg-white focus:ring-2 focus:ring-blue-500"
                                        placeholder="Especifique dirección exacta..."
                                        value={formData.direccionActual}
                                        onChange={(e) => setFormData({ ...formData, direccionActual: e.target.value })}
                                    />
                                </div>
                            </div>

                            {/* Fechas Aplicación Ficha */}
                            <div className="col-span-12 border-t pt-2 mt-2 border-gray-100 bg-blue-50/50 p-2 rounded -mx-2">
                                <div className="grid grid-cols-12 gap-4 items-center">
                                    <div className="col-span-12 md:col-span-3">
                                        <label className="text-[10px] font-black uppercase text-blue-800">Fecha Inicio Ficha:</label>
                                        <input
                                            type="date"
                                            className="mt-1 w-full px-2 py-1 border border-blue-200 rounded text-xs text-blue-900 bg-white"
                                            value={formData.fechaInicioFicha}
                                            onChange={(e) => setFormData({ ...formData, fechaInicioFicha: e.target.value })}
                                        />
                                    </div>
                                    <div className="col-span-12 md:col-span-3">
                                        <label className="text-[10px] font-black uppercase text-blue-800">Fecha Fin Ficha:</label>
                                        <input
                                            type="date"
                                            className="mt-1 w-full px-2 py-1 border border-blue-200 rounded text-xs text-blue-900 bg-white"
                                            value={formData.fechaFinFicha}
                                            onChange={(e) => setFormData({ ...formData, fechaFinFicha: e.target.value })}
                                        />
                                    </div>
                                    <div className="col-span-12 md:col-span-6 text-right">
                                        <p className="text-[10px] text-gray-400 italic">Complete estas fechas según la duración de la evaluación.</p>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                    {/* II. SITUACIÓN DE CALLE */}
                    <div className={`bg-white rounded-xl border border-gray-200 overflow-hidden ${activeTab === 'GENERAL' ? '' : 'hidden'}`}>
                        <div className="bg-gray-50 border-b border-gray-200 px-4 py-2">
                            <h2 className="text-sm font-black text-gray-900 uppercase">
                                II. SITUACIÓN DE CALLE
                            </h2>
                        </div>
                        <div className="p-4 grid grid-cols-12 gap-x-6 gap-y-6 text-xs">

                            {/* Perfil */}
                            <div className="col-span-12">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Perfil del Usuario/a</label>
                                <div className="flex flex-wrap gap-3">
                                    <label className="flex items-center gap-2 px-3 py-2 border border-gray-100 rounded-lg bg-gray-50/50 cursor-pointer hover:bg-gray-100">
                                        <input type="checkbox" checked={formData.situacionCalleDetalle.perfil.trabajoInfantil} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, perfil: { ...formData.situacionCalleDetalle.perfil, trabajoInfantil: e.target.checked } } })} className="w-4 h-4 text-blue-600 rounded" />
                                        <span className="font-bold text-[10px] text-gray-700 uppercase">Trabajo Infantil</span>
                                    </label>
                                    <label className="flex items-center gap-2 px-3 py-2 border border-gray-100 rounded-lg bg-gray-50/50 cursor-pointer hover:bg-gray-100">
                                        <input type="checkbox" checked={formData.situacionCalleDetalle.perfil.mendicidad} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, perfil: { ...formData.situacionCalleDetalle.perfil, mendicidad: e.target.checked } } })} className="w-4 h-4 text-blue-600 rounded" />
                                        <span className="font-bold text-[10px] text-gray-700 uppercase">Mendicidad</span>
                                    </label>
                                    <label className="flex items-center gap-2 px-3 py-2 border border-gray-100 rounded-lg bg-gray-50/50 cursor-pointer hover:bg-gray-100">
                                        <input type="checkbox" checked={formData.situacionCalleDetalle.perfil.vidaEnCalle} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, perfil: { ...formData.situacionCalleDetalle.perfil, vidaEnCalle: e.target.checked } } })} className="w-4 h-4 text-blue-600 rounded" />
                                        <span className="font-bold text-[10px] text-gray-700 uppercase">Vida en Calle</span>
                                    </label>
                                </div>
                                {(formData.situacionCalleDetalle.perfil.vidaEnCalle) && (
                                    <div className="mt-2 ml-4 flex gap-4">
                                        <label className="flex items-center gap-2"><input type="checkbox" checked={formData.situacionCalleDetalle.perfil.transito} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, perfil: { ...formData.situacionCalleDetalle.perfil, transito: e.target.checked } } })} className="rounded text-blue-600" /> <span className="text-[10px] text-gray-600 font-bold uppercase">Tránsito</span></label>
                                        <label className="flex items-center gap-2"><input type="checkbox" checked={formData.situacionCalleDetalle.perfil.convivencia} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, perfil: { ...formData.situacionCalleDetalle.perfil, convivencia: e.target.checked } } })} className="rounded text-blue-600" /> <span className="text-[10px] text-gray-600 font-bold uppercase">Convivencia</span></label>
                                    </div>
                                )}
                            </div>

                            <hr className="col-span-12 border-gray-100" />

                            {/* Tiempo y Explotación */}
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Tiempo en Calle</label>
                                <div className="flex gap-2">
                                    <input
                                        type="text"
                                        placeholder="Cant."
                                        className="w-20 px-3 py-2 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                        value={formData.situacionCalleDetalle.tiempo.cantidad}
                                        onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, tiempo: { ...formData.situacionCalleDetalle.tiempo, cantidad: e.target.value } } })}
                                    />
                                    <select
                                        className="flex-1 px-3 py-2 border border-gray-200 rounded-lg text-xs bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                        value={formData.situacionCalleDetalle.tiempo.unidad}
                                        onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, tiempo: { ...formData.situacionCalleDetalle.tiempo, unidad: e.target.value } } })}
                                    >
                                        <option value="SEMANAS">SEMANAS</option>
                                        <option value="MESES">MESES</option>
                                        <option value="AÑOS">AÑOS</option>
                                    </select>
                                </div>
                            </div>

                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">¿Víctima de Explotación Sexual?</label>
                                <div className="flex gap-6 mt-1">
                                    <label className="flex items-center gap-2 cursor-pointer">
                                        <input
                                            type="radio"
                                            name="explotacion_sexual"
                                            checked={formData.situacionCalleDetalle.explotacionSexual === true}
                                            onChange={() => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, explotacionSexual: true } })}
                                            className="w-4 h-4 text-red-600 focus:ring-red-500"
                                        />
                                        <span className="text-xs font-bold text-gray-700">SI</span>
                                    </label>
                                    <label className="flex items-center gap-2 cursor-pointer">
                                        <input
                                            type="radio"
                                            name="explotacion_sexual"
                                            checked={formData.situacionCalleDetalle.explotacionSexual === false}
                                            onChange={() => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, explotacionSexual: false } })}
                                            className="w-4 h-4 text-blue-600 focus:ring-blue-500"
                                        />
                                        <span className="text-xs font-bold text-gray-700">NO</span>
                                    </label>
                                </div>
                            </div>

                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Ingreso Aprox. Semanal</label>
                                <div className="relative">
                                    <span className="absolute left-3 top-2 text-gray-500 font-bold">S/</span>
                                    <input
                                        type="text"
                                        className="w-full pl-8 pr-3 py-2 border border-gray-200 rounded-lg text-xs font-bold focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                        placeholder="0.00"
                                        value={formData.situacionCalleDetalle.ingresoSemanal}
                                        onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, ingresoSemanal: e.target.value } })}
                                    />
                                </div>
                            </div>

                            <hr className="col-span-12 border-gray-100" />

                            {/* Horarios y Frecuencia */}
                            <div className="col-span-12 md:col-span-6">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Horarios en Calle</label>
                                <div className="grid grid-cols-3 gap-2">
                                    {['Manana', 'Tarde', 'Noche'].map(h => (
                                        <label key={h} className="flex flex-col items-center justify-center p-2 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer bg-white">
                                            <span className="text-[9px] font-bold uppercase mb-1">{h}</span>
                                            <input
                                                type="checkbox"
                                                checked={(formData.situacionCalleDetalle.horarios as any)[h.toLowerCase().replace('ñ', 'n')]}
                                                onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, horarios: { ...formData.situacionCalleDetalle.horarios, [h.toLowerCase().replace('ñ', 'n')]: e.target.checked } } })}
                                                className="w-4 h-4 text-purple-600 rounded"
                                            />
                                        </label>
                                    ))}
                                </div>
                            </div>

                            <div className="col-span-12 md:col-span-6">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Frecuencia en Calle</label>
                                <div className="grid grid-cols-2 gap-2">
                                    {['Diario', 'Interdiario', 'FinesSemana', 'Temporadas'].map(f => (
                                        <label key={f} className="flex items-center gap-2 p-2 border border-gray-100 rounded-lg bg-gray-50/50 hover:bg-gray-100 cursor-pointer">
                                            <input
                                                type="checkbox"
                                                checked={(formData.situacionCalleDetalle.frecuencia as any)[f === 'FinesSemana' ? 'finesSemana' : f.toLowerCase()]}
                                                onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, frecuencia: { ...formData.situacionCalleDetalle.frecuencia, [f === 'FinesSemana' ? 'finesSemana' : f.toLowerCase()]: e.target.checked } } })}
                                                className="w-3.5 h-3.5 text-indigo-600 rounded"
                                            />
                                            <span className="text-[10px] font-bold uppercase text-gray-700">{f.replace('FinesSemana', 'Fines de Semana')}</span>
                                        </label>
                                    ))}
                                </div>
                            </div>

                            <hr className="col-span-12 border-gray-100" />

                            {/* Motivo y Modalidad */}
                            <div className="col-span-12 md:col-span-6">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Motivo Situación de Calle</label>
                                <textarea
                                    className="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500 min-h-[80px]"
                                    placeholder="Describa el motivo..."
                                    value={formData.situacionCalleDetalle.motivo}
                                    onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, motivo: e.target.value } })}
                                />
                            </div>
                            <div className="col-span-12 md:col-span-6">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Modalidad de Trabajo</label>
                                <div className="space-y-2">
                                    <label className="flex items-center gap-2 cursor-pointer">
                                        <input type="checkbox" checked={formData.situacionCalleDetalle.modalidadTrabajo.puestoFijo} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, modalidadTrabajo: { ...formData.situacionCalleDetalle.modalidadTrabajo, puestoFijo: e.target.checked } } })} className="rounded text-green-600" />
                                        <span className="text-xs text-gray-700">Puesto Fijo</span>
                                    </label>
                                    <label className="flex items-center gap-2 cursor-pointer">
                                        <input type="checkbox" checked={formData.situacionCalleDetalle.modalidadTrabajo.ambulante} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, modalidadTrabajo: { ...formData.situacionCalleDetalle.modalidadTrabajo, ambulante: e.target.checked } } })} className="rounded text-green-600" />
                                        <span className="text-xs text-gray-700">Ambulante</span>
                                    </label>
                                    <label className="flex items-center gap-2 cursor-pointer">
                                        <input type="checkbox" checked={formData.situacionCalleDetalle.modalidadTrabajo.recorre} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, modalidadTrabajo: { ...formData.situacionCalleDetalle.modalidadTrabajo, recorre: e.target.checked } } })} className="rounded text-green-600" />
                                        <span className="text-xs text-gray-700">Recorre</span>
                                    </label>
                                </div>
                            </div>

                            {/* Actividad y Lugar */}
                            <div className="col-span-12 md:col-span-6">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Actividad en Calle</label>
                                <input
                                    type="text"
                                    className="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                    value={formData.situacionCalleDetalle.actividad}
                                    onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, actividad: e.target.value } })}
                                />
                            </div>
                            <div className="col-span-12 md:col-span-6">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Lugar / Zona</label>
                                <input
                                    type="text"
                                    className="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                    value={formData.situacionCalleDetalle.lugar}
                                    onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, lugar: e.target.value } })}
                                />
                            </div>

                            <hr className="col-span-12 border-gray-100" />

                            {/* Acompañamiento */}
                            <div className="col-span-12">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Acompañamiento en la Actividad</label>
                                <div className="grid grid-cols-12 gap-4 items-center">
                                    <div className="col-span-12 md:col-span-4 flex gap-4">
                                        <label className="flex items-center gap-2"><input type="checkbox" checked={formData.situacionCalleDetalle.acompanamiento.solo} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, acompanamiento: { ...formData.situacionCalleDetalle.acompanamiento, solo: e.target.checked } } })} className="rounded text-orange-600" /> <span className="text-xs font-bold uppercase">Solo</span></label>
                                        <label className="flex items-center gap-2"><input type="checkbox" checked={formData.situacionCalleDetalle.acompanamiento.acompanado} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, acompanamiento: { ...formData.situacionCalleDetalle.acompanamiento, acompanado: e.target.checked } } })} className="rounded text-orange-600" /> <span className="text-xs font-bold uppercase">Acompañado</span></label>
                                        <label className="flex items-center gap-2"><input type="checkbox" checked={formData.situacionCalleDetalle.acompanamiento.acompanadoFamiliar} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, acompanamiento: { ...formData.situacionCalleDetalle.acompanamiento, acompanadoFamiliar: e.target.checked } } })} className="rounded text-orange-600" /> <span className="text-xs font-bold uppercase">Familiar</span></label>
                                    </div>
                                    <div className="col-span-12 md:col-span-8">
                                        <input
                                            type="text"
                                            placeholder="¿Quién lo acompaña?"
                                            className="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs bg-gray-50 focus:bg-white transition-colors"
                                            value={formData.situacionCalleDetalle.acompanamiento.quien}
                                            onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, acompanamiento: { ...formData.situacionCalleDetalle.acompanamiento, quien: e.target.value } } })}
                                        />
                                    </div>
                                </div>
                            </div>

                            {/* Obligado y Escapó */}
                            <div className="col-span-12 md:col-span-6 bg-red-50 p-3 rounded-lg border border-red-100">
                                <div className="flex justify-between items-center mb-2">
                                    <label className="text-[10px] font-bold text-red-800 uppercase">¿Es obligado a trabajar?</label>
                                    <div className="flex gap-3">
                                        <label className="flex items-center gap-1"><input type="radio" name="obligado" checked={formData.situacionCalleDetalle.obligado.si} onChange={() => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, obligado: { si: true, no: false, quien: '' } } })} className="text-red-600" /> <span className="text-xs font-bold">SI</span></label>
                                        <label className="flex items-center gap-1"><input type="radio" name="obligado" checked={formData.situacionCalleDetalle.obligado.no} onChange={() => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, obligado: { si: false, no: true, quien: '' } } })} className="text-gray-600" /> <span className="text-xs font-bold">NO</span></label>
                                    </div>
                                </div>
                                <input
                                    type="text"
                                    placeholder="¿Quién lo obliga?"
                                    className="w-full px-2 py-1 border border-red-200 rounded text-xs bg-white"
                                    value={formData.situacionCalleDetalle.obligado.quien}
                                    onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, obligado: { ...formData.situacionCalleDetalle.obligado, quien: e.target.value } } })}
                                />
                            </div>

                            <div className="col-span-12 md:col-span-6 bg-yellow-50 p-3 rounded-lg border border-yellow-100">
                                <div className="flex justify-between items-center mb-2">
                                    <label className="text-[10px] font-bold text-yellow-800 uppercase">¿Escapó de casa?</label>
                                    <div className="flex gap-3">
                                        <label className="flex items-center gap-1"><input type="radio" name="escapo" checked={formData.situacionCalleDetalle.escapoCasa.si} onChange={() => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, escapoCasa: { si: true, no: false, veces: '' } } })} className="text-yellow-600" /> <span className="text-xs font-bold">SI</span></label>
                                        <label className="flex items-center gap-1"><input type="radio" name="escapo" checked={formData.situacionCalleDetalle.escapoCasa.no} onChange={() => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, escapoCasa: { si: false, no: true, veces: '' } } })} className="text-gray-600" /> <span className="text-xs font-bold">NO</span></label>
                                    </div>
                                </div>
                                <input
                                    type="text"
                                    placeholder="¿Cuántas veces?"
                                    className="w-full px-2 py-1 border border-yellow-200 rounded text-xs bg-white"
                                    value={formData.situacionCalleDetalle.escapoCasa.veces}
                                    onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, escapoCasa: { ...formData.situacionCalleDetalle.escapoCasa, veces: e.target.value } } })}
                                />
                            </div>

                            {/* Consumo */}
                            <div className="col-span-12 border-t border-gray-100 pt-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Consumo de Sustancias Psicoactivas</label>
                                <div className="grid grid-cols-12 gap-4 bg-gray-50 rounded-lg p-3 border border-gray-100">
                                    <div className="col-span-12 md:col-span-4 flex items-center justify-between">
                                        <span className="text-xs font-bold text-gray-700">¿Consume?</span>
                                        <div className="flex gap-3">
                                            <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="consumo" checked={formData.situacionCalleDetalle.consumo.si} onChange={() => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, consumo: { ...formData.situacionCalleDetalle.consumo, si: true, no: false } } })} className="text-red-600" /> <span className="text-xs font-bold">SI</span></label>
                                            <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="consumo" checked={formData.situacionCalleDetalle.consumo.no} onChange={() => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, consumo: { ...formData.situacionCalleDetalle.consumo, si: false, no: true } } })} className="text-green-600" /> <span className="text-xs font-bold">NO</span></label>
                                        </div>
                                    </div>
                                    <div className="col-span-12 md:col-span-8">
                                        <input
                                            type="text"
                                            placeholder="¿Qué tipo de sustancias?"
                                            className="w-full px-3 py-1.5 border border-gray-200 rounded text-xs bg-white"
                                            value={formData.situacionCalleDetalle.consumo.tipo}
                                            onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, consumo: { ...formData.situacionCalleDetalle.consumo, tipo: e.target.value } } })}
                                        />
                                    </div>
                                    <div className="col-span-12 md:col-span-6 flex items-center gap-3">
                                        <span className="text-[10px] font-bold text-gray-500 uppercase">Frecuencia:</span>
                                        <div className="flex gap-2">
                                            {['Experimental', 'Ocasional', 'Habitual'].map(fr => (
                                                <label key={fr} className="text-[10px] flex items-center gap-1">
                                                    <input type="radio" name="frecuenciaConsumo" value={fr.toUpperCase()} checked={formData.situacionCalleDetalle.consumo.frecuencia === fr.toUpperCase()} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, consumo: { ...formData.situacionCalleDetalle.consumo, frecuencia: e.target.value } } })} />
                                                    {fr}
                                                </label>
                                            ))}
                                        </div>
                                    </div>
                                    <div className="col-span-12 md:col-span-6 flex items-center gap-2">
                                        <span className="text-[10px] font-bold text-gray-500 uppercase">Tiempo:</span>
                                        <input type="text" className="w-16 px-2 py-1 border border-gray-200 rounded text-xs" placeholder="Cant." value={formData.situacionCalleDetalle.consumo.tiempo} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, consumo: { ...formData.situacionCalleDetalle.consumo, tiempo: e.target.value } } })} />
                                        <select className="px-2 py-1 border border-gray-200 rounded text-xs" value={formData.situacionCalleDetalle.consumo.unidadTiempo} onChange={e => setFormData({ ...formData, situacionCalleDetalle: { ...formData.situacionCalleDetalle, consumo: { ...formData.situacionCalleDetalle.consumo, unidadTiempo: e.target.value } } })}>
                                            <option value="SEMANAS">Semanas</option>
                                            <option value="MESES">Meses</option>
                                            <option value="AÑOS">Años</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                    {/* III. TUTOR */}
                    <div className={`bg-white rounded-xl border border-gray-200 overflow-hidden ${activeTab === 'GENERAL' ? '' : 'hidden'}`}>
                        <div className="bg-gray-50 border-b border-gray-200 px-4 py-2">
                            <h2 className="text-sm font-black text-gray-900 uppercase">
                                III. DATOS DEL TUTOR/APODERADO/FAMILIAR
                            </h2>
                        </div>
                        <div className="p-4 grid grid-cols-12 gap-x-6 gap-y-4 text-xs">

                            {/* Fila 1: Nombres y Fecha Nac */}
                            <div className="col-span-12 md:col-span-8">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Nombres y Apellidos</label>
                                <input
                                    type="text"
                                    className="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                    value={formData.tutorNombre}
                                    onChange={(e) => setFormData({ ...formData, tutorNombre: e.target.value })}
                                />
                            </div>
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Fecha de Nacimiento</label>
                                <input
                                    type="date"
                                    className="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                    value={formData.tutorFechaNacimiento}
                                    onChange={(e) => setFormData({ ...formData, tutorFechaNacimiento: e.target.value })}
                                />
                            </div>

                            {/* Fila 2: DNI */}
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">DNI</label>
                                <input
                                    type="text"
                                    className="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                    value={formData.tutorDNI}
                                    onChange={(e) => setFormData({ ...formData, tutorDNI: e.target.value })}
                                />
                            </div>

                            {/* Fila 3: Parentesco y Grado */}
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Parentesco con el usuario</label>
                                <input
                                    type="text"
                                    className="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                    value={formData.tutorParentesco}
                                    onChange={(e) => setFormData({ ...formData, tutorParentesco: e.target.value })}
                                />
                            </div>
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Grado de Instrucción</label>
                                <input
                                    type="text"
                                    className="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                    value={formData.tutorGradoInstruccion}
                                    onChange={(e) => setFormData({ ...formData, tutorGradoInstruccion: e.target.value })}
                                />
                            </div>

                            <hr className="col-span-12 border-gray-100" />

                            {/* Fila 4: Discapacidad y Estado Civil */}
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">¿Presenta alguna Discapacidad?</label>
                                <div className="flex gap-4 mt-2">
                                    <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="tutorDiscapacidad" value="SI" checked={formData.tutorDiscapacidad === 'SI'} onChange={() => setFormData({ ...formData, tutorDiscapacidad: 'SI' })} className="text-blue-600" /> <span className="font-bold text-gray-700">SI</span></label>
                                    <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="tutorDiscapacidad" value="NO" checked={formData.tutorDiscapacidad === 'NO'} onChange={() => setFormData({ ...formData, tutorDiscapacidad: 'NO' })} className="text-blue-600" /> <span className="font-bold text-gray-700">NO</span></label>
                                </div>
                            </div>
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Cuenta con carnet CONADIS</label>
                                <div className="flex gap-4 mt-2">
                                    <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="tutorConadis" value="SI" checked={formData.tutorConadis === 'SI'} onChange={() => setFormData({ ...formData, tutorConadis: 'SI' })} className="text-blue-600" /> <span className="font-bold text-gray-700">SI</span></label>
                                    <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="tutorConadis" value="NO" checked={formData.tutorConadis === 'NO'} onChange={() => setFormData({ ...formData, tutorConadis: 'NO' })} className="text-blue-600" /> <span className="font-bold text-gray-700">NO</span></label>
                                </div>
                            </div>
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Estado Civil</label>
                                <input
                                    type="text"
                                    className="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                    value={formData.tutorEstadoCivil}
                                    onChange={(e) => setFormData({ ...formData, tutorEstadoCivil: e.target.value })}
                                />
                            </div>

                            {/* Fila 5: Ocupación e Ingreso */}
                            <div className="col-span-12 md:col-span-8">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Ocupación</label>
                                <input
                                    type="text"
                                    className="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                    value={formData.tutorOcupacion}
                                    onChange={(e) => setFormData({ ...formData, tutorOcupacion: e.target.value })}
                                />
                            </div>
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Ingreso Aprox. Semanal</label>
                                <div className="relative">
                                    <span className="absolute left-3 top-2 text-gray-500 font-bold">S/</span>
                                    <input
                                        type="text"
                                        className="w-full pl-8 pr-3 py-2 border border-gray-200 rounded-lg text-xs font-bold focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                        placeholder="0.00"
                                        value={formData.tutorIngreso}
                                        onChange={(e) => setFormData({ ...formData, tutorIngreso: e.target.value })}
                                    />
                                </div>
                            </div>

                            <hr className="col-span-12 border-gray-100" />

                            {/* Fila 6: Consumo y Apoyo Alimentos */}
                            <div className="col-span-12 md:col-span-6">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">Consumo de Drogas</label>
                                <div className="flex gap-4 mt-2">
                                    <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="tutorConsumoDrogas" value="SI" checked={formData.tutorConsumoDrogas === 'SI'} onChange={() => setFormData({ ...formData, tutorConsumoDrogas: 'SI' })} className="text-red-500" /> <span className="font-bold text-gray-700">SI</span></label>
                                    <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="tutorConsumoDrogas" value="NO" checked={formData.tutorConsumoDrogas === 'NO'} onChange={() => setFormData({ ...formData, tutorConsumoDrogas: 'NO' })} className="text-green-600" /> <span className="font-bold text-gray-700">NO</span></label>
                                </div>
                            </div>
                            <div className="col-span-12 md:col-span-6">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-1">¿Recibe apoyo para alimentos del NNA?</label>
                                <div className="flex gap-4 mt-2">
                                    <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="tutorRecibeApoyo" value="SI" checked={formData.tutorRecibeApoyo === 'SI'} onChange={() => setFormData({ ...formData, tutorRecibeApoyo: 'SI' })} className="text-blue-600" /> <span className="font-bold text-gray-700">SI</span></label>
                                    <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="tutorRecibeApoyo" value="NO" checked={formData.tutorRecibeApoyo === 'NO'} onChange={() => setFormData({ ...formData, tutorRecibeApoyo: 'NO' })} className="text-blue-600" /> <span className="font-bold text-gray-700">NO</span></label>
                                </div>
                            </div>

                            {/* Fila 7: Demanda */}
                            <div className="col-span-12 bg-blue-50 p-3 rounded-lg border border-blue-100 flex items-center justify-between mt-2">
                                <label className="font-bold text-blue-900 uppercase text-[10px]">¿Desea realizar demanda por alimentos?</label>
                                <div className="flex gap-6">
                                    <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="tutorDeseaDemanda" value="SI" checked={formData.tutorDeseaDemanda === 'SI'} onChange={() => setFormData({ ...formData, tutorDeseaDemanda: 'SI' })} className="text-blue-700" /> <span className="text-xs font-bold text-blue-900">SI</span></label>
                                    <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="tutorDeseaDemanda" value="NO" checked={formData.tutorDeseaDemanda === 'NO'} onChange={() => setFormData({ ...formData, tutorDeseaDemanda: 'NO' })} className="text-blue-700" /> <span className="text-xs font-bold text-blue-900">NO</span></label>
                                </div>
                            </div>

                        </div>
                    </div>



                    {/* IV. DATOS DE LA FAMILIA */}
                    <div className={activeTab === 'FAMILIA' ? '' : 'hidden'}>
                        <div className="flex items-center justify-between mb-4">
                            <h3 className="text-xs font-black text-gray-500 uppercase tracking-widest border-b border-gray-100 pb-2">
                                IV. Datos de la Familia
                            </h3>
                            <button
                                onClick={handleAddFamily}
                                className="flex items-center gap-2 bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition-colors text-sm font-bold"
                            >
                                <Plus size={16} /> Agregar Familiar
                            </button>
                        </div>

                        {formData.familiares.length > 0 ? (
                            <div className="border border-gray-200 rounded-lg overflow-hidden">
                                <table className="w-full text-sm">
                                    <thead className="bg-gray-50 text-xs">
                                        <tr>
                                            <th className="px-3 py-2 text-left">N°</th>
                                            <th className="px-3 py-2 text-left">Apellidos y Nombres</th>
                                            <th className="px-3 py-2 text-left">Parentesco</th>
                                            <th className="px-3 py-2 text-left">Edad</th>
                                            <th className="px-3 py-2 text-left">Sexo</th>
                                            <th className="px-3 py-2 text-left">G. Instrucción</th>
                                            <th className="px-3 py-2 text-left">Ocupación</th>
                                            <th className="px-3 py-2 text-center">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {formData.familiares.map((familiar, idx) => (
                                            <tr key={idx} className="border-t border-gray-100">
                                                <td className="px-3 py-2 font-bold text-gray-400">{idx + 1}</td>
                                                <td className="px-3 py-2">{`${familiar.primerApellido} ${familiar.segundoApellido} ${familiar.nombres}`.trim()}</td>
                                                <td className="px-3 py-2">{familiar.parentesco}</td>
                                                <td className="px-3 py-2">{familiar.edad}</td>
                                                <td className="px-3 py-2">{familiar.sexo}</td>
                                                <td className="px-3 py-2 text-xs">{familiar.gradoInstruccion}</td>
                                                <td className="px-3 py-2 text-xs">{familiar.ocupacion}</td>
                                                <td className="px-3 py-2">
                                                    <div className="flex gap-2 justify-center">
                                                        <button
                                                            onClick={() => handleEditFamily(idx)}
                                                            className="p-1 text-blue-600 hover:bg-blue-50 rounded transition-colors"
                                                            title="Editar"
                                                        >
                                                            <Edit2 size={14} />
                                                        </button>
                                                        <button
                                                            onClick={() => handleDeleteFamily(idx)}
                                                            className="p-1 text-red-600 hover:bg-red-50 rounded transition-colors"
                                                            title="Eliminar"
                                                        >
                                                            <Trash2 size={14} />
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>
                            </div>
                        ) : (
                            <div className="border-2 border-dashed border-gray-200 rounded-lg p-8 text-center">
                                <p className="text-gray-400 text-sm mb-3">No hay familiares registrados</p>
                                <button
                                    onClick={handleAddFamily}
                                    className="text-green-600 text-sm font-bold hover:text-green-700"
                                >
                                    + Agregar el primer familiar
                                </button>
                            </div>
                        )}

                        <div className="mt-6 border-t border-gray-100 pt-4">
                            <h4 className="text-xs font-black text-gray-500 uppercase tracking-widest mb-4">Relación con la Familia</h4>

                            <div className="grid grid-cols-12 gap-4 text-xs">
                                {/* Contacto y Frecuencia */}
                                <div className="col-span-12 md:col-span-4">
                                    <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">¿Tiene contacto con su familia?</label>
                                    <div className="flex gap-4">
                                        <label className="flex items-center gap-1 font-bold"><input type="radio" checked={formData.dinamicaFamiliar.contacto === 'SI'} onChange={() => setFormData({ ...formData, dinamicaFamiliar: { ...formData.dinamicaFamiliar, contacto: 'SI' } })} /> SI</label>
                                        <label className="flex items-center gap-1 font-bold"><input type="radio" checked={formData.dinamicaFamiliar.contacto === 'NO'} onChange={() => setFormData({ ...formData, dinamicaFamiliar: { ...formData.dinamicaFamiliar, contacto: 'NO' } })} /> NO</label>
                                    </div>
                                </div>

                                <div className="col-span-12 md:col-span-8">
                                    <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Frecuencia</label>
                                    <div className="flex flex-wrap gap-4">
                                        {['DIARIO', 'INTERDIARIO', 'FINES DE SEMANA', 'MESES', 'AÑOS'].map(opt => (
                                            <label key={opt} className="flex items-center gap-1 text-[10px]">
                                                <input type="radio" checked={formData.dinamicaFamiliar.frecuencia === opt} onChange={() => setFormData({ ...formData, dinamicaFamiliar: { ...formData.dinamicaFamiliar, frecuencia: opt } })} />
                                                {opt}
                                            </label>
                                        ))}
                                    </div>
                                </div>

                                <div className="col-span-12 mt-2">
                                    <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Padres asumen su rol (X)</label>
                                    <div className="grid grid-cols-1 md:grid-cols-2 gap-6 border border-gray-100 rounded-lg p-3 bg-gray-50">
                                        {/* Protector */}
                                        <div>
                                            <div className="text-center font-bold mb-2 text-gray-600 border-b border-gray-200 pb-1">PROTECTOR</div>
                                            <div className="flex justify-center gap-4">
                                                <label className="flex items-center gap-1"><input type="radio" checked={formData.dinamicaFamiliar.rolProtector === 'SI'} onChange={() => setFormData({ ...formData, dinamicaFamiliar: { ...formData.dinamicaFamiliar, rolProtector: 'SI' } })} /> SI</label>
                                                <label className="flex items-center gap-1"><input type="radio" checked={formData.dinamicaFamiliar.rolProtector === 'NO'} onChange={() => setFormData({ ...formData, dinamicaFamiliar: { ...formData.dinamicaFamiliar, rolProtector: 'NO' } })} /> NO</label>
                                                <label className="flex items-center gap-1"><input type="radio" checked={formData.dinamicaFamiliar.rolProtector === 'REGULAR'} onChange={() => setFormData({ ...formData, dinamicaFamiliar: { ...formData.dinamicaFamiliar, rolProtector: 'REGULAR' } })} /> REGULAR</label>
                                            </div>
                                        </div>

                                        {/* Proveedor */}
                                        <div>
                                            <div className="text-center font-bold mb-2 text-gray-600 border-b border-gray-200 pb-1">PROVEEDOR</div>
                                            <div className="flex justify-center gap-4">
                                                <label className="flex items-center gap-1"><input type="radio" checked={formData.dinamicaFamiliar.rolProveedor === 'SI'} onChange={() => setFormData({ ...formData, dinamicaFamiliar: { ...formData.dinamicaFamiliar, rolProveedor: 'SI' } })} /> SI</label>
                                                <label className="flex items-center gap-1"><input type="radio" checked={formData.dinamicaFamiliar.rolProveedor === 'NO'} onChange={() => setFormData({ ...formData, dinamicaFamiliar: { ...formData.dinamicaFamiliar, rolProveedor: 'NO' } })} /> NO</label>
                                                <label className="flex items-center gap-1"><input type="radio" checked={formData.dinamicaFamiliar.rolProveedor === 'REGULAR'} onChange={() => setFormData({ ...formData, dinamicaFamiliar: { ...formData.dinamicaFamiliar, rolProveedor: 'REGULAR' } })} /> REGULAR</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>

                    </div>

                    {/* V. DATOS DE LA VIVIENDA */}
                    <div className={`bg-white rounded-xl border border-gray-200 overflow-hidden mt-6 ${activeTab === 'FAMILIA' ? '' : 'hidden'}`}>
                        <div className="bg-gray-50 border-b border-gray-200 px-4 py-2">
                            <h2 className="text-sm font-black text-gray-900 uppercase">
                                V. DATOS DE LA VIVIENDA
                            </h2>
                        </div>
                        <div className="p-4 grid grid-cols-12 gap-x-6 gap-y-6 text-xs">

                            {/* Fila 1: Material */}
                            <div className="col-span-12 md:col-span-4 relative group">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Material de Vivienda (X)</label>
                                <div className="flex gap-2 bg-gray-50 p-2 rounded-lg border border-gray-100">
                                    <label className="flex-1 flex items-center justify-center gap-2 cursor-pointer hover:bg-white p-2 rounded transition-all shadow-sm border border-transparent hover:border-gray-200">
                                        <input type="radio" name="material" value="CONCRETO" checked={formData.materialVivienda === 'CONCRETO'} onChange={(e) => setFormData({ ...formData, materialVivienda: e.target.value })} className="text-blue-600 focus:ring-blue-500" />
                                        <span className="font-semibold text-gray-700">Concreto</span>
                                    </label>
                                    <label className="flex-1 flex items-center justify-center gap-2 cursor-pointer hover:bg-white p-2 rounded transition-all shadow-sm border border-transparent hover:border-gray-200">
                                        <input type="radio" name="material" value="PRECARIO" checked={formData.materialVivienda === 'PRECARIO'} onChange={(e) => setFormData({ ...formData, materialVivienda: e.target.value })} className="text-blue-600 focus:ring-blue-500" />
                                        <span className="font-semibold text-gray-700">Precario</span>
                                    </label>
                                </div>
                            </div>

                            {/* Fila 1: Ambientes */}
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Número de Ambientes</label>
                                <div className="flex gap-2 bg-gray-50 p-2 rounded-lg border border-gray-100 text-center">
                                    {['1', '2', '3'].map(opt => (
                                        <label key={opt} className="flex-1 cursor-pointer hover:bg-white p-2 rounded transition-all shadow-sm border border-transparent hover:border-gray-200">
                                            <input type="radio" name="ambientes" value={opt} checked={formData.numeroAmbientes === opt} onChange={(e) => setFormData({ ...formData, numeroAmbientes: e.target.value })} className="sr-only peer" />
                                            <span className="block font-bold text-gray-500 peer-checked:text-blue-600 peer-checked:scale-110 transition-transform">{opt}</span>
                                        </label>
                                    ))}
                                </div>
                            </div>

                            {/* Fila 1: Propiedad */}
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Propiedad de la Vivienda</label>
                                <div className="grid grid-cols-2 gap-2 bg-gray-50 p-2 rounded-lg border border-gray-100">
                                    {['OTROS', 'PROPIA', 'ALQUILADA', 'ALOJADO'].map(opt => (
                                        <label key={opt} className="flex items-center gap-2 cursor-pointer hover:bg-white p-1 px-2 rounded transition-all border border-transparent hover:border-gray-200">
                                            <input type="radio" name="propiedad" value={opt} checked={formData.propiedadVivienda === opt} onChange={(e) => setFormData({ ...formData, propiedadVivienda: e.target.value })} className="text-blue-600 focus:ring-blue-500" />
                                            <span className="text-[10px] font-semibold text-gray-700 truncate" title={opt}>{opt === 'ALOJADO' ? 'ALOJADO/INV.' : opt}</span>
                                        </label>
                                    ))}
                                </div>
                            </div>

                            <hr className="col-span-12 border-gray-100" />

                            {/* Fila 2: SISFOH y Cama (Agrupados) */}
                            <div className="col-span-12 md:col-span-4 space-y-4">
                                <div>
                                    <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Vivienda inscrita en SISFOH</label>
                                    <div className="flex gap-4">
                                        <label className="flex items-center gap-2 cursor-pointer"><input type="radio" name="sisfoh" value="SI" checked={formData.viviendaSisfoh === 'SI'} onChange={(e) => setFormData({ ...formData, viviendaSisfoh: e.target.value })} className="text-blue-600" /> <span className="font-bold">SI</span></label>
                                        <label className="flex items-center gap-2 cursor-pointer"><input type="radio" name="sisfoh" value="NO" checked={formData.viviendaSisfoh === 'NO'} onChange={(e) => setFormData({ ...formData, viviendaSisfoh: e.target.value })} className="text-blue-600" /> <span className="font-bold">NO</span></label>
                                    </div>
                                </div>

                                <div>
                                    <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Duerme en una Cama</label>
                                    <div className="flex gap-4 mb-2">
                                        <label className="flex items-center gap-2 cursor-pointer"><input type="radio" name="cama" value="SI" checked={formData.duermeCama === 'SI'} onChange={(e) => setFormData({ ...formData, duermeCama: e.target.value })} className="text-blue-600" /> <span className="font-bold">SI</span></label>
                                        <label className="flex items-center gap-2 cursor-pointer"><input type="radio" name="cama" value="NO" checked={formData.duermeCama === 'NO'} onChange={(e) => setFormData({ ...formData, duermeCama: e.target.value })} className="text-blue-600" /> <span className="font-bold">NO</span></label>
                                    </div>
                                    <input
                                        type="text"
                                        placeholder="¿Con quién?"
                                        className="w-full border-b border-gray-300 focus:border-blue-500 outline-none text-xs py-1 bg-transparent"
                                        value={formData.duermeConQuien}
                                        onChange={(e) => setFormData({ ...formData, duermeConQuien: e.target.value })}
                                    />
                                    <div className="flex gap-4 mt-2 text-[10px]">
                                        <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="solo" value="SOLO" checked={formData.duermeSoloAcompanado === 'SOLO'} onChange={(e) => setFormData({ ...formData, duermeSoloAcompanado: e.target.value })} /> SOLO</label>
                                        <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="solo" value="ACOMPAÑADO" checked={formData.duermeSoloAcompanado === 'ACOMPAÑADO'} onChange={(e) => setFormData({ ...formData, duermeSoloAcompanado: e.target.value })} /> ACOMPAÑADO</label>
                                    </div>
                                </div>
                            </div>

                            {/* Fila 2: Servicios Básicos */}
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Servicios Básicos</label>
                                <div className="space-y-2 bg-blue-50 p-3 rounded-lg border border-blue-100">
                                    <label className="flex items-center gap-2 cursor-pointer hover:bg-blue-100 p-1 rounded transition-colors">
                                        <input type="checkbox" checked={formData.serviciosBasicos.agua} onChange={(e) => setFormData({ ...formData, serviciosBasicos: { ...formData.serviciosBasicos, agua: e.target.checked } })} className="rounded text-blue-600 focus:ring-blue-500" />
                                        <span className="font-medium text-gray-700">Agua</span>
                                    </label>
                                    <label className="flex items-center gap-2 cursor-pointer hover:bg-blue-100 p-1 rounded transition-colors">
                                        <input type="checkbox" checked={formData.serviciosBasicos.luz} onChange={(e) => setFormData({ ...formData, serviciosBasicos: { ...formData.serviciosBasicos, luz: e.target.checked } })} className="rounded text-blue-600 focus:ring-blue-500" />
                                        <span className="font-medium text-gray-700">Luz</span>
                                    </label>
                                    <label className="flex items-center gap-2 cursor-pointer hover:bg-blue-100 p-1 rounded transition-colors">
                                        <input type="checkbox" checked={formData.serviciosBasicos.desague} onChange={(e) => setFormData({ ...formData, serviciosBasicos: { ...formData.serviciosBasicos, desague: e.target.checked } })} className="rounded text-blue-600 focus:ring-blue-500" />
                                        <span className="font-medium text-gray-700">Desagüe</span>
                                    </label>
                                    <label className="flex items-center gap-2 cursor-pointer hover:bg-blue-100 p-1 rounded transition-colors">
                                        <input type="checkbox" checked={formData.serviciosBasicos.otros} onChange={(e) => setFormData({ ...formData, serviciosBasicos: { ...formData.serviciosBasicos, otros: e.target.checked } })} className="rounded text-blue-600 focus:ring-blue-500" />
                                        <span className="font-medium text-gray-700">Otros</span>
                                    </label>
                                </div>
                            </div>

                            {/* Fila 2: Higiene */}
                            <div className="col-span-12 md:col-span-4">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Higiene en el domicilio</label>
                                <div className="space-y-1">
                                    {['BUENO', 'REGULAR', 'MALO', 'PESIMO'].map(opt => (
                                        <label key={opt} className={`flex items-center gap-3 cursor-pointer p-2 rounded-lg border transition-all ${formData.higieneDomicilio === opt ? 'bg-green-50 border-green-200 shadow-sm' : 'border-transparent hover:bg-gray-50'}`}>
                                            <input type="radio" name="higiene" value={opt} checked={formData.higieneDomicilio === opt} onChange={(e) => setFormData({ ...formData, higieneDomicilio: e.target.value })} className="text-green-600 focus:ring-green-500" />
                                            <span className={`text-xs font-bold ${formData.higieneDomicilio === opt ? 'text-green-800' : 'text-gray-600'}`}>{opt}</span>
                                        </label>
                                    ))}
                                </div>
                            </div>

                            <hr className="col-span-12 border-gray-100" />

                            {/* Fila 3: Albergue */}
                            <div className="col-span-12">
                                <label className="block text-[10px] font-bold text-gray-400 uppercase mb-2">Antecedente en CAR / Albergue</label>
                                <div className="flex flex-col md:flex-row items-start gap-6 bg-gray-50 p-4 rounded-xl border border-gray-100">
                                    {/* SI/NO Radio */}
                                    <div>
                                        <span className="text-xs font-bold text-gray-500 block mb-2">¿Estuvo en Albergue?</span>
                                        <div className="flex gap-4">
                                            <label className="flex items-center gap-2 cursor-pointer select-none">
                                                <div className={`w-8 h-8 rounded-full flex items-center justify-center font-bold text-white transition-colors ${formData.tieneAntecedenteAlbergue ? 'bg-blue-600' : 'bg-gray-300 text-gray-400'}`}>
                                                    {formData.tieneAntecedenteAlbergue ? 'SI' : ''}
                                                </div>
                                                <input
                                                    type="radio"
                                                    name="antecedenteAlbergue"
                                                    checked={formData.tieneAntecedenteAlbergue === true}
                                                    onChange={() => setFormData({ ...formData, tieneAntecedenteAlbergue: true })}
                                                    className="hidden"
                                                />
                                                <span className={`text-xs font-bold ${formData.tieneAntecedenteAlbergue ? 'text-blue-700' : 'text-gray-400'}`}>SI</span>
                                            </label>

                                            <label className="flex items-center gap-2 cursor-pointer select-none">
                                                <div className={`w-8 h-8 rounded-full flex items-center justify-center font-bold text-white transition-colors ${formData.tieneAntecedenteAlbergue === false ? 'bg-blue-600' : 'bg-gray-300 text-gray-400'}`}>
                                                    {formData.tieneAntecedenteAlbergue === false ? 'NO' : ''}
                                                </div>
                                                <input
                                                    type="radio"
                                                    name="antecedenteAlbergue"
                                                    checked={formData.tieneAntecedenteAlbergue === false}
                                                    onChange={() => setFormData({ ...formData, tieneAntecedenteAlbergue: false })}
                                                    className="hidden"
                                                />
                                                <span className={`text-xs font-bold ${formData.tieneAntecedenteAlbergue === false ? 'text-blue-700' : 'text-gray-400'}`}>NO</span>
                                            </label>
                                        </div>
                                    </div>

                                    <div className="flex-1 grid grid-cols-2 gap-4 w-full">
                                        <div>
                                            <label className="block text-[9px] font-bold text-gray-400 uppercase mb-1">¿Cuánto Tiempo?</label>
                                            <input
                                                type="text"
                                                className="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 bg-white"
                                                placeholder="Ej: 3 meses"
                                                value={formData.tiempoAlbergue}
                                                onChange={(e) => setFormData({ ...formData, tiempoAlbergue: e.target.value })}
                                                disabled={!formData.tieneAntecedenteAlbergue}
                                            />
                                        </div>
                                        <div>
                                            <label className="block text-[9px] font-bold text-gray-400 uppercase mb-1">Motivo</label>
                                            <input
                                                type="text"
                                                className="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs focus:ring-2 focus:ring-blue-500 bg-white"
                                                placeholder="Especifique motivo..."
                                                value={formData.detalleAntecedenteAlbergue}
                                                onChange={(e) => setFormData({ ...formData, detalleAntecedenteAlbergue: e.target.value })}
                                                disabled={!formData.tieneAntecedenteAlbergue}
                                            />
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>


                    {/* VI. EDUCACIÓN */}
                    <div className={`bg-white rounded-xl border border-gray-200 overflow-hidden mt-6 shadow-sm ${activeTab === 'EDUCACION' ? '' : 'hidden'}`}>
                        <div className="bg-gradient-to-r from-gray-50 to-white border-b border-gray-200 px-4 py-3 flex items-center justify-between">
                            <h2 className="text-sm font-black text-gray-800 uppercase tracking-wide flex items-center gap-2">
                                <span className="bg-blue-600 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs">VI</span>
                                EDUCACIÓN - NNA
                            </h2>
                        </div>

                        <div className="p-5 grid grid-cols-12 gap-x-6 gap-y-6 text-xs">

                            {/* BLOCK 1: SITUACIÓN ACADÉMICA */}
                            <div className="col-span-12 md:col-span-12">
                                <h3 className="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3 border-b border-gray-100 pb-1">Situación Académica</h3>
                                <div className="grid grid-cols-12 gap-4">

                                    {/* Estudia (Toggle Big) */}
                                    <div className="col-span-12 md:col-span-2 flex flex-col items-center justify-center p-2 bg-gray-50 rounded-lg">
                                        <span className="text-[10px] font-bold text-gray-500 uppercase mb-2">¿Estudia Actualmente?</span>
                                        <div className="flex bg-gray-200 p-1 rounded-full relative w-24 h-8 cursor-pointer shadow-inner">
                                            <div onClick={() => setFormData({ ...formData, eduEstudia: 'SI' })} className={`w-1/2 rounded-full flex items-center justify-center z-10 transition-all duration-300 font-bold ${formData.eduEstudia === 'SI' ? 'text-white' : 'text-gray-500 hover:text-gray-700'}`}>SI</div>
                                            <div onClick={() => setFormData({ ...formData, eduEstudia: 'NO' })} className={`w-1/2 rounded-full flex items-center justify-center z-10 transition-all duration-300 font-bold ${formData.eduEstudia === 'NO' ? 'text-white' : 'text-gray-500 hover:text-gray-700'}`}>NO</div>
                                            <div className={`absolute top-1 bottom-1 w-[45%] bg-blue-600 rounded-full transition-all duration-300 shadow-sm ${formData.eduEstudia === 'NO' ? 'translate-x-[110%]' : 'translate-x-[5%]'} `}></div>
                                        </div>
                                    </div>

                                    {/* Modalidad (Segmented) */}
                                    <div className="col-span-12 md:col-span-4">
                                        <label className="block text-[10px] font-bold text-gray-500 uppercase mb-1">Modalidad</label>
                                        <div className="flex bg-gray-50 p-1 rounded-lg border border-gray-200">
                                            {['REGULAR', 'ALTERNATIVA', 'ESPECIAL'].map(opt => (
                                                <button key={opt} onClick={() => setFormData({ ...formData, eduModalidad: opt })} className={`flex-1 py-1.5 px-2 rounded-md text-[9px] font-bold transition-all ${formData.eduModalidad === opt ? 'bg-white shadow text-blue-700 border border-gray-100' : 'text-gray-400 hover:bg-gray-100 hover:text-gray-600'}`}>
                                                    {opt}
                                                </button>
                                            ))}
                                        </div>
                                    </div>

                                    {/* Turno (Select/Combo or Segmented) */}
                                    <div className="col-span-12 md:col-span-3">
                                        <label className="block text-[10px] font-bold text-gray-500 uppercase mb-1">Turno</label>
                                        <select
                                            className="w-full bg-gray-50 border border-gray-200 text-gray-700 text-xs rounded-lg focus:ring-blue-500 focus:border-blue-500 block p-2 font-medium"
                                            value={formData.eduTurno}
                                            onChange={(e) => setFormData({ ...formData, eduTurno: e.target.value })}
                                        >
                                            <option value="">Seleccione...</option>
                                            <option value="MAÑANA">MAÑANA</option>
                                            <option value="TARDE">TARDE</option>
                                            <option value="NOCHE">NOCHE</option>
                                        </select>
                                    </div>

                                    {/* Nivel (Tabs) */}
                                    <div className="col-span-12 md:col-span-3">
                                        <label className="block text-[10px] font-bold text-gray-500 uppercase mb-1">Nivel</label>
                                        <div className="flex space-x-1">
                                            {['INICIAL', 'PRIMARIA', 'SECUNDARIA'].map(opt => (
                                                <div
                                                    key={opt}
                                                    onClick={() => setFormData({ ...formData, eduNivel: opt })}
                                                    className={`flex-1 cursor-pointer text-center py-2 rounded-t-lg border-b-2 font-bold transition-colors ${formData.eduNivel === opt ? 'border-blue-500 text-blue-600 bg-blue-50' : 'border-transparent text-gray-400 hover:bg-gray-50'}`}
                                                >
                                                    {opt.substring(0, 3)}
                                                </div>
                                            ))}
                                        </div>
                                    </div>

                                </div>
                            </div>

                            {/* BLOCK 2: DETALLES IE */}
                            <div className="col-span-12 md:col-span-12 grid grid-cols-12 gap-4">
                                <div className="col-span-12 md:col-span-5">
                                    <label className="block text-[10px] font-bold text-gray-500 uppercase mb-1">Institución Educativa</label>
                                    <div className="flex">
                                        <select
                                            className="w-24 bg-gray-100 border border-gray-200 text-gray-700 text-xs rounded-l-lg focus:ring-blue-500 focus:border-blue-500 p-2 font-bold"
                                            value={formData.eduTipoIE}
                                            onChange={(e) => setFormData({ ...formData, eduTipoIE: e.target.value })}
                                        >
                                            <option value="">Tipo</option>
                                            <option value="PUBLICA">PÚBLICA</option>
                                            <option value="PRIVADA">PRIVADA</option>
                                        </select>
                                        <input
                                            type="text"
                                            placeholder="Nombre de la I.E."
                                            className="flex-1 bg-white border border-gray-200 border-l-0 text-gray-700 text-xs rounded-r-lg focus:ring-blue-500 focus:border-blue-500 p-2"
                                            value={formData.eduNombreIE}
                                            onChange={(e) => setFormData({ ...formData, eduNombreIE: e.target.value })}
                                        />
                                    </div>
                                </div>

                                <div className="col-span-6 md:col-span-2">
                                    <label className="block text-[10px] font-bold text-gray-500 uppercase mb-1">Grado</label>
                                    <input
                                        type="text"
                                        className="w-full bg-white border border-gray-200 text-gray-700 text-xs rounded-lg focus:ring-blue-500 focus:border-blue-500 p-2 text-center font-bold"
                                        placeholder="Ej: 3ro"
                                        value={formData.eduGrado}
                                        onChange={(e) => setFormData({ ...formData, eduGrado: e.target.value })}
                                    />
                                </div>

                                <div className="col-span-6 md:col-span-5 bg-orange-50 p-2 rounded-lg border border-orange-100">
                                    <div className="flex items-center justify-between mb-2">
                                        <label className="text-[10px] font-bold text-orange-700 uppercase">¿Atraso Escolar?</label>
                                        <div className="flex gap-2">
                                            <label className="flex items-center gap-1 cursor-pointer"><input type="radio" checked={formData.presentaAtraso} onChange={() => setFormData({ ...formData, presentaAtraso: true })} className="text-orange-600" /> SI</label>
                                            <label className="flex items-center gap-1 cursor-pointer"><input type="radio" checked={!formData.presentaAtraso} onChange={() => setFormData({ ...formData, presentaAtraso: false })} className="text-orange-600" /> NO</label>
                                        </div>
                                    </div>
                                    {formData.presentaAtraso && (
                                        <div className="flex gap-2 items-center">
                                            <select
                                                className="flex-1 text-[10px] p-1 rounded border-orange-200 border text-gray-700"
                                                value={formData.eduAtrasoMotivoDetalle}
                                                onChange={(e) => setFormData({ ...formData, eduAtrasoMotivoDetalle: e.target.value })}
                                            >
                                                <option value="">Motivo...</option>
                                                <option value="REPITIO">REPITIO</option>
                                                <option value="DESERTO">DESERTO</option>
                                                <option value="NO ESTUDIO">NO ESTUDIO</option>
                                            </select>
                                            <input
                                                type="text"
                                                placeholder="Años"
                                                className="w-12 text-[10px] p-1 rounded border-orange-200 border text-center"
                                                value={formData.tiempoAtraso}
                                                onChange={(e) => setFormData({ ...formData, tiempoAtraso: e.target.value })}
                                            />
                                        </div>
                                    )}
                                </div>
                            </div>

                            {/* BLOCK 3: INDICADORES DE RIESGO */}
                            <div className="col-span-12">
                                <h3 className="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3 border-b border-gray-100 pb-1 mt-2">Indicadores de Riesgo</h3>
                                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">

                                    {/* Helper Component for Yes/No Cards */}
                                    {[
                                        { label: 'Problemas Aprendizaje', key: 'eduProblemasAprendizaje' },
                                        { label: 'Problemas Conductuales', key: 'eduProbConductuales', extra: true },
                                        { label: 'Ha sido Expulsado', key: 'eduExpulsado', extraInput: 'eduExpulsadoVeces', placeholder: 'N° Veces' },
                                        { label: 'Faltas / Tardanzas', key: 'eduFaltasTardanzas' },
                                        { label: 'Se duerme en clase', key: 'eduDuermeClase' },
                                        { label: 'Bullying / Discriminación', key: 'eduBullying' },
                                        { label: 'Padre conversa con docente', key: 'eduPadreConversa' }
                                    ].map((item: any) => (
                                        <div key={item.key} className={`p-3 rounded-xl border transition-all ${formData[item.key] === 'SI' ? 'bg-red-50 border-red-200' : 'bg-gray-50 border-transparent hover:border-gray-200'}`}>
                                            <div className="flex justify-between items-center">
                                                <span className={`text-[10px] font-bold uppercase ${formData[item.key] === 'SI' ? 'text-red-700' : 'text-gray-500'}`}>{item.label}</span>
                                                <div className="flex bg-white rounded-lg border border-gray-200 p-0.5 shadow-sm">
                                                    <div onClick={() => setFormData({ ...formData, [item.key]: 'SI' })} className={`px-2 py-0.5 text-[9px] font-bold rounded cursor-pointer transition-colors ${formData[item.key] === 'SI' ? 'bg-red-500 text-white' : 'text-gray-400 hover:text-red-500'}`}>SI</div>
                                                    <div onClick={() => setFormData({ ...formData, [item.key]: 'NO' })} className={`px-2 py-0.5 text-[9px] font-bold rounded cursor-pointer transition-colors ${formData[item.key] === 'NO' ? 'bg-gray-500 text-white' : 'text-gray-400 hover:text-gray-600'}`}>NO</div>
                                                </div>
                                            </div>

                                            {/* Extra Content for Conducta */}
                                            {item.extra && formData[item.key] === 'SI' && (
                                                <div className="mt-2 flex gap-1 justify-center bg-white p-1 rounded border border-gray-100">
                                                    {['LEVE', 'MODERADO', 'SEVERO'].map(level => (
                                                        <div
                                                            key={level}
                                                            onClick={() => setFormData({ ...formData, eduProbConductualesIntensidad: level })}
                                                            className={`flex-1 text-[8px] text-center rounded py-1 cursor-pointer font-bold ${formData.eduProbConductualesIntensidad === level
                                                                ? (level === 'LEVE' ? 'bg-green-100 text-green-700' : level === 'MODERADO' ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700')
                                                                : 'text-gray-400 hover:bg-gray-50'}`}
                                                        >
                                                            {level}
                                                        </div>
                                                    ))}
                                                </div>
                                            )}

                                            {/* Extra Input for Expulsado */}
                                            {item.extraInput && formData[item.key] === 'SI' && (
                                                <div className="mt-2">
                                                    <input
                                                        type="text"
                                                        placeholder={item.placeholder}
                                                        className="w-full text-center text-xs border border-gray-200 rounded p-1"
                                                        value={formData[item.extraInput]}
                                                        onChange={(e) => setFormData({ ...formData, [item.extraInput]: e.target.value })}
                                                    />
                                                </div>
                                            )}
                                        </div>
                                    ))}

                                </div>
                            </div>

                        </div>
                    </div>


                    {/* VII. SALUD - ALIMENTACIÓN - HIGIENE */}
                    <div className={`bg-white rounded-xl border border-gray-200 overflow-hidden mt-6 shadow-sm ${activeTab === 'SALUD' ? '' : 'hidden'}`}>
                        <div className="bg-gradient-to-r from-gray-50 to-white border-b border-gray-200 px-4 py-3 flex items-center justify-between">
                            <h2 className="text-sm font-black text-gray-800 uppercase tracking-wide flex items-center gap-2">
                                <span className="bg-emerald-600 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs">VII</span>
                                SALUD - ALIMENTACIÓN - HIGIENE
                            </h2>
                        </div>

                        <div className="p-5 grid grid-cols-12 gap-6 text-xs">

                            {/* --- 1. SALUD FÍSICA --- */}
                            <div className="col-span-12 md:col-span-6 bg-emerald-50/50 rounded-xl border border-emerald-100 p-4">
                                <h3 className="text-emerald-800 font-bold uppercase text-[10px] mb-3 border-b border-emerald-200 pb-1">1. Salud Física</h3>

                                <div className="mb-4">
                                    <label className="block text-[9px] font-bold text-gray-400 uppercase mb-2">Presenta Problemas en:</label>
                                    <div className="flex flex-wrap gap-2">
                                        {['PIEL', 'DESNUTRICION', 'RESPIRATORIOS', 'ITS', 'OTROS'].map(opt => {
                                            const key = opt.toLowerCase();
                                            return (
                                                <label key={opt} className={`cursor-pointer px-3 py-1.5 rounded-lg border text-[9px] font-bold transition-all ${formData.saludProblemas[key] ? 'bg-emerald-500 text-white border-emerald-600 shadow-sm' : 'bg-white text-gray-500 border-gray-200 hover:border-emerald-300'}`}>
                                                    <input type="checkbox" className="hidden" checked={formData.saludProblemas[key]} onChange={(e) => setFormData({ ...formData, saludProblemas: { ...formData.saludProblemas, [key]: e.target.checked } })} />
                                                    {opt}
                                                </label>
                                            );
                                        })}
                                    </div>
                                </div>

                                <div className="grid grid-cols-2 gap-4 mb-4">
                                    <div>
                                        <label className="block text-[9px] font-bold text-gray-400 uppercase mb-1">Enfermedad Crónica</label>
                                        <div className="flex bg-white rounded border border-gray-200 p-0.5 w-fit">
                                            <div onClick={() => setFormData({ ...formData, saludEnfermedadCronica: 'SI' })} className={`px-3 py-1 rounded cursor-pointer font-bold transition-colors ${formData.saludEnfermedadCronica === 'SI' ? 'bg-emerald-500 text-white' : 'text-gray-400 hover:text-emerald-500'}`}>SI</div>
                                            <div onClick={() => setFormData({ ...formData, saludEnfermedadCronica: 'NO' })} className={`px-3 py-1 rounded cursor-pointer font-bold transition-colors ${formData.saludEnfermedadCronica === 'NO' ? 'bg-gray-400 text-white' : 'text-gray-400 hover:text-gray-600'}`}>NO</div>
                                        </div>
                                    </div>

                                    {formData.saludEnfermedadCronica === 'SI' && (
                                        <div>
                                            <label className="block text-[9px] font-bold text-gray-400 uppercase mb-1">¿Recibe Tratamiento?</label>
                                            <div className="flex bg-white rounded border border-gray-200 p-0.5 w-fit">
                                                <div onClick={() => setFormData({ ...formData, saludRecibeTratamiento: 'SI' })} className={`px-3 py-1 rounded cursor-pointer font-bold transition-colors ${formData.saludRecibeTratamiento === 'SI' ? 'bg-emerald-500 text-white' : 'text-gray-400 hover:text-emerald-500'}`}>SI</div>
                                                <div onClick={() => setFormData({ ...formData, saludRecibeTratamiento: 'NO' })} className={`px-3 py-1 rounded cursor-pointer font-bold transition-colors ${formData.saludRecibeTratamiento === 'NO' ? 'bg-gray-400 text-white' : 'text-gray-400 hover:text-gray-600'}`}>NO</div>
                                            </div>
                                        </div>
                                    )}
                                </div>

                                <div className="border-t border-emerald-200 pt-3">
                                    <div className="flex justify-between items-start mb-2">
                                        <div>
                                            <label className="block text-[9px] font-bold text-gray-400 uppercase mb-1">¿Sufre Discapacidad?</label>
                                            <div className="flex bg-white rounded border border-gray-200 p-0.5 w-fit">
                                                <div onClick={() => setFormData({ ...formData, saludDiscapacidad: 'SI' })} className={`px-3 py-1 rounded cursor-pointer font-bold transition-colors ${formData.saludDiscapacidad === 'SI' ? 'bg-emerald-500 text-white' : 'text-gray-400 hover:text-emerald-500'}`}>SI</div>
                                                <div onClick={() => setFormData({ ...formData, saludDiscapacidad: 'NO' })} className={`px-3 py-1 rounded cursor-pointer font-bold transition-colors ${formData.saludDiscapacidad === 'NO' ? 'bg-gray-400 text-white' : 'text-gray-400 hover:text-gray-600'}`}>NO</div>
                                            </div>
                                        </div>
                                        {formData.saludDiscapacidad === 'SI' && (
                                            <div>
                                                <label className="block text-[9px] font-bold text-gray-400 uppercase mb-1">Carnet CONADIS</label>
                                                <div className="flex bg-white rounded border border-gray-200 p-0.5 w-fit ml-auto">
                                                    <div onClick={() => setFormData({ ...formData, saludCarnetConadis: 'SI' })} className={`px-2 py-0.5 rounded cursor-pointer font-bold transition-colors ${formData.saludCarnetConadis === 'SI' ? 'bg-blue-500 text-white' : 'text-gray-400 hover:text-blue-500'}`}>SI</div>
                                                    <div onClick={() => setFormData({ ...formData, saludCarnetConadis: 'NO' })} className={`px-2 py-0.5 rounded cursor-pointer font-bold transition-colors ${formData.saludCarnetConadis === 'NO' ? 'bg-gray-400 text-white' : 'text-gray-400 hover:text-gray-600'}`}>NO</div>
                                                </div>
                                            </div>
                                        )}
                                    </div>

                                    {formData.saludDiscapacidad === 'SI' && (
                                        <div className="mt-3 bg-white p-2 rounded border border-emerald-100">
                                            <label className="block text-[9px] font-bold text-gray-400 uppercase mb-2">Tipo de Discapacidad</label>
                                            <div className="flex flex-wrap gap-2 mb-3">
                                                {['MENTAL', 'SENSORIAL/MOTORA', 'FISICA', 'INTELECTUAL'].map(type => (
                                                    <div key={type} onClick={() => setFormData({ ...formData, saludTipoDiscapacidad: type })} className={`cursor-pointer px-2 py-1 rounded text-[8px] font-bold border transition-colors ${formData.saludTipoDiscapacidad === type ? 'bg-emerald-100 border-emerald-300 text-emerald-700' : 'border-gray-100 text-gray-400 hover:bg-gray-50'}`}>{type}</div>
                                                ))}
                                            </div>
                                            <label className="block text-[9px] font-bold text-gray-400 uppercase mb-1">Lugar de Tratamiento</label>
                                            <select className="w-full text-xs p-1 border border-gray-200 rounded text-gray-600" value={formData.saludLugarTratamiento} onChange={(e) => setFormData({ ...formData, saludLugarTratamiento: e.target.value })}>
                                                <option value="">Seleccione...</option>
                                                <option value="HOSPITAL">HOSPITAL</option>
                                                <option value="CENTRO DE SALUD">CENTRO DE SALUD</option>
                                                <option value="OTRO">OTRO</option>
                                            </select>
                                        </div>
                                    )}
                                </div>
                            </div>

                            {/* --- 2. SALUD MENTAL Y ADICCIONES --- */}
                            <div className="col-span-12 md:col-span-6 bg-purple-50/50 rounded-xl border border-purple-100 p-4">
                                <h3 className="text-purple-800 font-bold uppercase text-[10px] mb-3 border-b border-purple-200 pb-1">2. Salud Mental y Riesgos</h3>

                                <div className="mb-4">
                                    <div className="flex justify-between items-center mb-2">
                                        <label className="text-[9px] font-bold text-purple-700 uppercase">Indicadores Psicológicos</label>
                                        <div className="flex bg-white rounded border border-gray-200 p-0.5">
                                            <div onClick={() => setFormData({ ...formData, psicoIndicadores: 'SI' })} className={`px-2 py-0.5 rounded cursor-pointer font-bold transition-colors ${formData.psicoIndicadores === 'SI' ? 'bg-purple-500 text-white' : 'text-gray-400 hover:text-purple-500'}`}>SI</div>
                                            <div onClick={() => setFormData({ ...formData, psicoIndicadores: 'NO' })} className={`px-2 py-0.5 rounded cursor-pointer font-bold transition-colors ${formData.psicoIndicadores === 'NO' ? 'bg-gray-400 text-white' : 'text-gray-400 hover:text-gray-600'}`}>NO</div>
                                        </div>
                                    </div>

                                    {formData.psicoIndicadores === 'SI' && (
                                        <div className="bg-white p-2 rounded border border-purple-100 animate-in fade-in slide-in-from-top-1">
                                            <div className="flex flex-wrap gap-2 mb-2">
                                                {['AUTOESTIMA BAJA', 'DEPRESION', 'ANSIEDAD', 'IMPULSIVIDAD'].map(opt => {
                                                    const key = opt.split(' ')[0].toLowerCase();
                                                    return (
                                                        <label key={opt} className={`cursor-pointer px-2 py-1 rounded border text-[8px] font-bold transition-all ${formData.psicoTipoIndicador[key] ? 'bg-purple-100 text-purple-700 border-purple-200' : 'bg-gray-50 text-gray-400 border-transparent hover:bg-gray-100'}`}>
                                                            <input type="checkbox" className="hidden" checked={formData.psicoTipoIndicador[key]} onChange={(e) => setFormData({ ...formData, psicoTipoIndicador: { ...formData.psicoTipoIndicador, [key]: e.target.checked } })} />
                                                            {opt}
                                                        </label>
                                                    );
                                                })}
                                            </div>
                                            <textarea
                                                className="w-full text-xs p-2 border border-purple-100 rounded bg-purple-50/30 focus:outline-none focus:border-purple-300 placeholder-purple-200"
                                                rows={2}
                                                placeholder="Detalles importantes..."
                                                value={formData.psicoDetalles}
                                                onChange={(e) => setFormData({ ...formData, psicoDetalles: e.target.value })}
                                            />
                                        </div>
                                    )}
                                </div>

                                <div className="space-y-3">
                                    <div className="flex justify-between items-center p-2 rounded-lg bg-white border border-gray-100">
                                        <span className="text-[9px] font-bold text-gray-500 uppercase">Si presenta Adicción (Recibe Tratamiento)</span>
                                        <div className="flex bg-gray-100 rounded p-0.5">
                                            <div onClick={() => setFormData({ ...formData, adiccionTratamiento: 'SI' })} className={`px-2 py-0.5 rounded cursor-pointer font-bold ${formData.adiccionTratamiento === 'SI' ? 'bg-blue-500 text-white' : 'text-gray-400 hover:text-blue-500'}`}>SI</div>
                                            <div onClick={() => setFormData({ ...formData, adiccionTratamiento: 'NO' })} className={`px-2 py-0.5 rounded cursor-pointer font-bold ${formData.adiccionTratamiento === 'NO' ? 'bg-gray-400 text-white' : 'text-gray-400 hover:text-gray-600'}`}>NO</div>
                                        </div>
                                    </div>

                                    {/* Situaciones Específicas */}
                                    <div className="grid grid-cols-2 gap-2">
                                        {[
                                            { label: 'Gestando', key: 'condicionGestando' },
                                            { label: 'Padre/Madre Adolesc.', key: 'condicionPadreAdolescente' },
                                            { label: 'Ha sufrido Aborto', key: 'condicionAborto', danger: true },
                                            { label: 'Víctima Abuso Sexual', key: 'condicionAbusoSexual', danger: true }
                                        ].map(item => (
                                            <div key={item.key} className={`flex justify-between items-center p-2 rounded border ${formData[item.key] === 'SI' ? (item.danger ? 'bg-red-50 border-red-200' : 'bg-blue-50 border-blue-200') : 'bg-gray-50 border-transparent hover:border-gray-200'}`}>
                                                <span className={`text-[8px] font-bold uppercase leading-tight ${formData[item.key] === 'SI' && item.danger ? 'text-red-700' : 'text-gray-500'}`}>{item.label}</span>
                                                <div className="flex bg-white rounded p-0.5 border border-gray-100 shadow-sm">
                                                    <div onClick={() => setFormData({ ...formData, [item.key]: 'SI' })} className={`px-1.5 py-0.5 rounded cursor-pointer font-bold text-[8px] ${formData[item.key] === 'SI' ? (item.danger ? 'bg-red-500 text-white' : 'bg-blue-500 text-white') : 'text-gray-300 hover:text-gray-500'}`}>SI</div>
                                                    <div onClick={() => setFormData({ ...formData, [item.key]: 'NO' })} className={`px-1.5 py-0.5 rounded cursor-pointer font-bold text-[8px] ${formData[item.key] === 'NO' ? 'bg-gray-500 text-white' : 'text-gray-300 hover:text-gray-500'}`}>NO</div>
                                                </div>
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>

                            {/* --- 3. ALIMENTACIÓN --- */}
                            <div className="col-span-12 md:col-span-12 bg-orange-50/50 rounded-xl border border-orange-100 p-4">
                                <h3 className="text-orange-800 font-bold uppercase text-[10px] mb-3 border-b border-orange-200 pb-1">3. Alimentación</h3>
                                <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
                                    <div className="md:col-span-1">
                                        <label className="block text-[9px] font-bold text-gray-400 uppercase mb-2">¿Recibe 3 alimentos al día?</label>
                                        <div className="flex gap-2">
                                            <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="alim3" checked={formData.alimTresComidas === 'SI'} onChange={() => setFormData({ ...formData, alimTresComidas: 'SI' })} className="text-orange-500" /> <span className="font-bold text-gray-600">SI</span></label>
                                            <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="alim3" checked={formData.alimTresComidas === 'NO'} onChange={() => setFormData({ ...formData, alimTresComidas: 'NO' })} className="text-orange-500" /> <span className="font-bold text-gray-600">NO</span></label>
                                        </div>
                                    </div>
                                    <div className="md:col-span-1">
                                        <label className="block text-[9px] font-bold text-gray-400 uppercase mb-2">Aparenta estar bien alimentado</label>
                                        <div className="flex gap-2">
                                            <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="alimBien" checked={formData.alimBienAlimentado === 'SI'} onChange={() => setFormData({ ...formData, alimBienAlimentado: 'SI' })} className="text-orange-500" /> <span className="font-bold text-gray-600">SI</span></label>
                                            <label className="flex items-center gap-1 cursor-pointer"><input type="radio" name="alimBien" checked={formData.alimBienAlimentado === 'NO'} onChange={() => setFormData({ ...formData, alimBienAlimentado: 'NO' })} className="text-orange-500" /> <span className="font-bold text-gray-600">NO</span></label>
                                        </div>
                                    </div>
                                    <div className="md:col-span-2">
                                        <div className="grid grid-cols-2 gap-4">
                                            <div>
                                                <label className="block text-[9px] font-bold text-gray-400 uppercase mb-1">Donde recibe alimentos</label>
                                                <div className="flex flex-wrap gap-1">
                                                    {['CALLE', 'HOGAR', 'OTRO'].map(opt => (
                                                        <div key={opt} onClick={() => setFormData({ ...formData, alimLugar: opt })} className={`cursor-pointer px-2 py-1 rounded text-[8px] font-bold border transition-colors ${formData.alimLugar === opt ? 'bg-orange-100 border-orange-300 text-orange-700' : 'bg-white border-orange-100/50 text-gray-400 hover:bg-orange-50'}`}>{opt}</div>
                                                    ))}
                                                </div>
                                            </div>
                                            <div>
                                                <label className="block text-[9px] font-bold text-gray-400 uppercase mb-1">Quien asume alimentación</label>
                                                <select className="w-full text-[10px] p-1 border border-orange-200 rounded text-gray-600 bg-white" value={formData.alimQuienAsume} onChange={(e) => setFormData({ ...formData, alimQuienAsume: e.target.value })}>
                                                    <option value="">Seleccione...</option>
                                                    <option value="USUARIO">USUARIO</option>
                                                    <option value="PADRE/TUTOR">PADRE / TUTOR</option>
                                                    <option value="INSTITUCION">INSTITUCION</option>
                                                    <option value="OTROS">OTROS</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            {/* --- 4. HIGIENE --- */}
                            <div className="col-span-12 md:col-span-8">
                                <h3 className="text-gray-600 font-bold uppercase text-[10px] mb-3 border-b border-gray-100 pb-1">4. Higiene y Cuidados</h3>
                                <div className="space-y-2">
                                    {[
                                        { label: 'Se asea diariamente', key: 'higieneAseaDiario' },
                                        { label: 'Utiliza ropas limpias', key: 'higieneRopaLimpia' },
                                        { label: 'Cumple normas higiene al comer', key: 'higieneNormasComer' },
                                        { label: 'Cabello / Uñas recortadas', key: 'higieneCabelloUnas' }
                                    ].map(item => (
                                        <div key={item.key} className="grid grid-cols-12 items-center gap-2 hover:bg-gray-50 p-1 rounded transition-colors">
                                            <div className="col-span-6 text-[10px] font-bold text-gray-500 uppercase">{item.label}</div>
                                            <div className="col-span-6 flex gap-1">
                                                {['SI', 'NO', 'A VECES'].map(opt => (
                                                    <div
                                                        key={opt}
                                                        onClick={() => setFormData({ ...formData, [item.key]: opt })}
                                                        className={`flex-1 text-center py-1 rounded cursor-pointer text-[9px] font-bold border transition-all ${formData[item.key] === opt ? 'bg-blue-50 border-blue-200 text-blue-700' : 'bg-white border-gray-100 text-gray-300 hover:text-gray-500'}`}
                                                    >
                                                        {opt}
                                                    </div>
                                                ))}
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>

                            {/* --- 5. VIOLENCIA --- */}
                            <div className="col-span-12 md:col-span-4 bg-red-50/30 rounded-xl border border-red-100 p-4">
                                <h3 className="text-red-800 font-bold uppercase text-[10px] mb-3 border-b border-red-200 pb-1">5. Situación de Violencia</h3>
                                <div className="mb-3">
                                    <label className="block text-[9px] font-bold text-gray-500 uppercase mb-2 text-center leading-tight">¿Los padres/tutor ejercen violencia para corregir?</label>
                                    <div className="flex justify-center gap-4">
                                        <div onClick={() => setFormData({ ...formData, violenciaPadres: 'SI' })} className={`w-12 h-12 rounded-full flex items-center justify-center font-black cursor-pointer shadow-sm transition-transform hover:scale-105 ${formData.violenciaPadres === 'SI' ? 'bg-red-600 text-white' : 'bg-gray-200 text-gray-400'}`}>SI</div>
                                        <div onClick={() => setFormData({ ...formData, violenciaPadres: 'NO' })} className={`w-12 h-12 rounded-full flex items-center justify-center font-black cursor-pointer shadow-sm transition-transform hover:scale-105 ${formData.violenciaPadres === 'NO' ? 'bg-gray-500 text-white' : 'bg-gray-200 text-gray-400'}`}>NO</div>
                                    </div>
                                </div>

                                {formData.violenciaPadres === 'SI' && (
                                    <div className="animate-in fade-in slide-in-from-bottom-2">
                                        <div className="bg-red-50 p-2 rounded mb-2">
                                            <label className="block text-[9px] font-bold text-red-400 uppercase mb-1 text-center">Tipo de Violencia</label>
                                            <div className="flex justify-center gap-2">
                                                <label className="flex items-center gap-1 cursor-pointer font-bold text-[9px] text-red-700"><input type="checkbox" checked={formData.violenciaTipo.fisica} onChange={(e) => setFormData({ ...formData, violenciaTipo: { ...formData.violenciaTipo, fisica: e.target.checked } })} className="rounded text-red-600 focus:ring-red-500" /> FISICA</label>
                                                <label className="flex items-center gap-1 cursor-pointer font-bold text-[9px] text-red-700"><input type="checkbox" checked={formData.violenciaTipo.psicologica} onChange={(e) => setFormData({ ...formData, violenciaTipo: { ...formData.violenciaTipo, psicologica: e.target.checked } })} className="rounded text-red-600 focus:ring-red-500" /> PSICOLÓGICA</label>
                                            </div>
                                        </div>
                                        <input
                                            type="text"
                                            className="w-full text-xs p-2 border border-red-200 rounded focus:ring-red-500"
                                            placeholder="¿Quién ejerce la violencia?"
                                            value={formData.violenciaQuien}
                                            onChange={(e) => setFormData({ ...formData, violenciaQuien: e.target.value })}
                                        />
                                    </div>
                                )}
                            </div>

                        </div>
                    </div>


                    {/* VIII. RECREACIÓN E INTERESES */}
                    <div className={`bg-white rounded-xl border border-gray-200 overflow-hidden mt-6 shadow-sm ${activeTab === 'SALUD' ? '' : 'hidden'}`}>
                        <div className="bg-gradient-to-r from-gray-50 to-white border-b border-gray-200 px-4 py-3 flex items-center justify-between">
                            <h2 className="text-sm font-black text-gray-800 uppercase tracking-wide flex items-center gap-2">
                                <span className="bg-pink-500 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs">VIII</span>
                                RECREACIÓN E INTERESES DEL NNA
                            </h2>
                        </div>

                        <div className="p-5 grid grid-cols-12 gap-6 text-xs">

                            {/* --- 1. TIEMPO LIBRE --- */}
                            <div className="col-span-12 md:col-span-6 bg-pink-50/40 rounded-xl border border-pink-100 p-4">
                                <h3 className="text-pink-800 font-bold uppercase text-[10px] mb-3 border-b border-pink-200 pb-1 flex items-center gap-2">
                                    <span className="text-lg">⚽</span> Tiempo Libre y Juego
                                </h3>

                                <div className="mb-4">
                                    <div className="flex justify-between items-center bg-white p-2 rounded-lg border border-pink-100 shadow-sm">
                                        <label className="text-[10px] font-bold text-gray-500 uppercase">¿Cuenta con tiempo para jugar?</label>
                                        <div className="flex bg-gray-100 rounded-lg p-0.5">
                                            <div onClick={() => setFormData({ ...formData, recreacionTiempoJuego: 'SI' })} className={`px-3 py-1 rounded-md cursor-pointer font-bold transition-all shadow-sm ${formData.recreacionTiempoJuego === 'SI' ? 'bg-pink-500 text-white' : 'text-gray-400 hover:text-pink-500 hover:bg-white'}`}>SI</div>
                                            <div onClick={() => setFormData({ ...formData, recreacionTiempoJuego: 'NO' })} className={`px-3 py-1 rounded-md cursor-pointer font-bold transition-all shadow-sm ${formData.recreacionTiempoJuego === 'NO' ? 'bg-gray-500 text-white' : 'text-gray-400 hover:text-gray-600 hover:bg-white'}`}>NO</div>
                                        </div>
                                    </div>

                                    {formData.recreacionTiempoJuego === 'SI' && (
                                        <div className="mt-3 space-y-3 animate-in fade-in slide-in-from-top-2">
                                            <div>
                                                <label className="block text-[9px] font-bold text-pink-400 uppercase mb-1">Frecuencia (Veces por semana)</label>
                                                <input
                                                    type="number"
                                                    className="w-full text-xs p-2 border border-pink-200 rounded-lg focus:ring-pink-500 bg-white"
                                                    placeholder="Ej: 3"
                                                    value={formData.recreacionVecesSemana}
                                                    onChange={(e) => setFormData({ ...formData, recreacionVecesSemana: e.target.value })}
                                                />
                                            </div>
                                            <div>
                                                <label className="block text-[9px] font-bold text-pink-400 uppercase mb-1">Lugar donde juega</label>
                                                <div className="flex gap-2">
                                                    {['CALLE/PARQUE', 'CASA', 'OTRO'].map(opt => (
                                                        <div
                                                            key={opt}
                                                            onClick={() => setFormData({ ...formData, recreacionLugar: opt })}
                                                            className={`flex-1 text-center py-2 rounded-lg cursor-pointer text-[8px] font-bold border transition-all ${formData.recreacionLugar === opt ? 'bg-pink-100 border-pink-300 text-pink-700 shadow-sm' : 'bg-white border-gray-100 text-gray-400 hover:border-pink-200'}`}
                                                        >
                                                            {opt}
                                                        </div>
                                                    ))}
                                                </div>
                                            </div>
                                        </div>
                                    )}
                                </div>

                                <div className="mt-4 pt-4 border-t border-pink-100">
                                    <div className="flex items-center justify-between p-2 rounded-lg bg-pink-100/50 border border-pink-200">
                                        <span className="text-[9px] font-bold text-pink-800 uppercase leading-tight w-2/3">Actividades Recreativas con Familia</span>
                                        <div className="flex gap-2">
                                            <label className="flex items-center gap-1 cursor-pointer"><input type="radio" checked={formData.recreacionActividadFamilia === 'SI'} onChange={() => setFormData({ ...formData, recreacionActividadFamilia: 'SI' })} className="text-pink-600" /> <span className="font-bold text-[9px]">SI</span></label>
                                            <label className="flex items-center gap-1 cursor-pointer"><input type="radio" checked={formData.recreacionActividadFamilia === 'NO'} onChange={() => setFormData({ ...formData, recreacionActividadFamilia: 'NO' })} className="text-pink-600" /> <span className="font-bold text-[9px]">NO</span></label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            {/* --- 2. INTERESES --- */}
                            <div className="col-span-12 md:col-span-6 space-y-4">
                                <div className="bg-blue-50/50 rounded-xl border border-blue-100 p-4">
                                    <h3 className="text-blue-800 font-bold uppercase text-[10px] mb-3 border-b border-blue-200 pb-1 flex items-center gap-2">
                                        <span className="text-lg">🎨</span> Intereses y Talentos
                                    </h3>

                                    <div className="space-y-3">
                                        <div>
                                            <label className="block text-[9px] font-bold text-gray-500 uppercase mb-1">Intereses Deportivos</label>
                                            <input
                                                type="text"
                                                className="w-full text-xs p-2 border border-blue-200 rounded-lg focus:ring-blue-500 bg-white placeholder-blue-200"
                                                placeholder="Ej: Fútbol, Voley..."
                                                value={formData.recreacionInteresDeporte}
                                                onChange={(e) => setFormData({ ...formData, recreacionInteresDeporte: e.target.value })}
                                            />
                                        </div>
                                        <div>
                                            <label className="block text-[9px] font-bold text-gray-500 uppercase mb-1">Intereses Artísticos</label>
                                            <input
                                                type="text"
                                                className="w-full text-xs p-2 border border-blue-200 rounded-lg focus:ring-blue-500 bg-white placeholder-blue-200"
                                                placeholder="Ej: Dibujo, Baile, Música..."
                                                value={formData.recreacionInteresArte}
                                                onChange={(e) => setFormData({ ...formData, recreacionInteresArte: e.target.value })}
                                            />
                                        </div>
                                    </div>
                                </div>

                                <div className="bg-indigo-50/50 rounded-xl border border-indigo-100 p-4">
                                    <h3 className="text-indigo-800 font-bold uppercase text-[10px] mb-3 border-b border-indigo-200 pb-1 flex items-center gap-2">
                                        <span className="text-lg">🏫</span> Participación Institucional
                                    </h3>

                                    <div className="flex justify-between items-center mb-3">
                                        <label className="text-[9px] font-bold text-indigo-700 uppercase">¿Participa en alguna institución?</label>
                                        <div className="flex bg-white rounded border border-indigo-100 p-0.5 shadow-sm">
                                            <div onClick={() => setFormData({ ...formData, recreacionParticipaInstitucion: 'SI' })} className={`px-2 py-0.5 rounded cursor-pointer font-bold transition-colors ${formData.recreacionParticipaInstitucion === 'SI' ? 'bg-indigo-600 text-white' : 'text-gray-400 hover:text-indigo-600'}`}>SI</div>
                                            <div onClick={() => setFormData({ ...formData, recreacionParticipaInstitucion: 'NO' })} className={`px-2 py-0.5 rounded cursor-pointer font-bold transition-colors ${formData.recreacionParticipaInstitucion === 'NO' ? 'bg-gray-400 text-white' : 'text-gray-400 hover:text-gray-600'}`}>NO</div>
                                        </div>
                                    </div>

                                    {formData.recreacionParticipaInstitucion === 'SI' && (
                                        <div className="space-y-2 animate-in fade-in">
                                            <div className="grid grid-cols-2 gap-2">
                                                {['IGLESIA', 'CLUB CULTURAL', 'CLUB DEPORTIVO', 'OTROS'].map(opt => (
                                                    <div
                                                        key={opt}
                                                        onClick={() => setFormData({ ...formData, recreacionTipoInstitucion: opt })}
                                                        className={`text-center py-1.5 rounded cursor-pointer text-[8px] font-bold border transition-all ${formData.recreacionTipoInstitucion === opt ? 'bg-indigo-100 border-indigo-300 text-indigo-800 shadow-sm' : 'bg-white border-indigo-50 text-gray-400 hover:bg-indigo-50'}`}
                                                    >
                                                        {opt}
                                                    </div>
                                                ))}
                                            </div>
                                            <input
                                                type="text"
                                                className="w-full text-xs p-2 border border-indigo-200 rounded-lg bg-white"
                                                placeholder="Nombre de la institución..."
                                                value={formData.recreacionInstitucionDetalle}
                                                onChange={(e) => setFormData({ ...formData, recreacionInstitucionDetalle: e.target.value })}
                                            />
                                        </div>
                                    )}
                                </div>
                            </div>

                        </div>
                    </div>


                    {/* IX. NECESIDADES Y PLAN DE ACCIÓN */}
                    <div className={activeTab === 'NECESIDADES' ? '' : 'hidden'}>
                        <div className="flex items-center justify-between mb-4">
                            <h3 className="text-xs font-black text-gray-500 uppercase tracking-widest border-b border-gray-100 pb-2">
                                IX. Necesidades del NNA y Plan de Acción
                            </h3>
                            <button
                                onClick={handleAddNeed}
                                className="flex items-center gap-2 bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-700 transition-colors text-sm font-bold"
                            >
                                <Plus size={16} /> Agregar Necesidad
                            </button>
                        </div>

                        {formData.necesidades.length > 0 ? (
                            <div className="border border-gray-200 rounded-lg overflow-hidden">
                                <table className="w-full text-sm">
                                    <thead className="bg-gray-50 text-xs">
                                        <tr>
                                            <th className="px-3 py-2 text-left" style={{ width: '5%' }}>N°</th>
                                            <th className="px-3 py-2 text-left" style={{ width: '15%' }}>Categoría</th>
                                            <th className="px-3 py-2 text-left" style={{ width: '20%' }}>Descripción</th>
                                            <th className="px-3 py-2 text-left" style={{ width: '17%' }}>Fase I</th>
                                            <th className="px-3 py-2 text-left" style={{ width: '17%' }}>Fase II</th>
                                            <th className="px-3 py-2 text-left" style={{ width: '17%' }}>Fase III</th>
                                            <th className="px-3 py-2 text-center" style={{ width: '9%' }}>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {formData.necesidades.map((necesidad, idx) => (
                                            <tr key={idx} className="border-t border-gray-100">
                                                <td className="px-3 py-2 font-bold text-gray-400 text-center">{idx + 1}</td>
                                                <td className="px-3 py-2">
                                                    <span className="inline-block px-2 py-1 bg-purple-100 text-purple-800 text-xs font-bold rounded">
                                                        {necesidad.categoria}
                                                    </span>
                                                </td>
                                                <td className="px-3 py-2 text-xs">{necesidad.descripcion}</td>
                                                <td className="px-3 py-2 text-xs text-gray-600">{necesidad.faseI || '-'}</td>
                                                <td className="px-3 py-2 text-xs text-gray-600">{necesidad.faseII || '-'}</td>
                                                <td className="px-3 py-2 text-xs text-gray-600">{necesidad.faseIII || '-'}</td>
                                                <td className="px-3 py-2">
                                                    <div className="flex gap-2 justify-center">
                                                        <button
                                                            onClick={() => handleEditNeed(idx)}
                                                            className="p-1 text-blue-600 hover:bg-blue-50 rounded transition-colors"
                                                            title="Editar"
                                                        >
                                                            <Edit2 size={14} />
                                                        </button>
                                                        <button
                                                            onClick={() => handleDeleteNeed(idx)}
                                                            className="p-1 text-red-600 hover:bg-red-50 rounded transition-colors"
                                                            title="Eliminar"
                                                        >
                                                            <Trash2 size={14} />
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>
                            </div>
                        ) : (
                            <div className="border-2 border-dashed border-gray-200 rounded-lg p-8 text-center">
                                <p className="text-gray-400 text-sm mb-3">No hay necesidades registradas</p>
                                <p className="text-xs text-gray-500 mb-4">Agrega las necesidades identificadas del NNA y el plan de acción por fases</p>
                                <button
                                    onClick={handleAddNeed}
                                    className="text-purple-600 text-sm font-bold hover:text-purple-700"
                                >
                                    + Agregar la primera necesidad
                                </button>
                            </div>
                        )}
                    </div>

                </div>

            </div>

            {/* MODAL PARA AGREGAR/EDITAR FAMILIAR */}
            {
                showFamilyModal && (
                    <div className="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 p-4">
                        <div className="bg-white rounded-xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
                            {/* Header del Modal */}
                            <div className="flex items-center justify-between p-6 border-b border-gray-200">
                                <h3 className="text-xl font-bold text-gray-800">
                                    {editingFamilyIndex !== null ? 'Editar Familiar' : 'Agregar Familiar'}
                                </h3>
                                <button
                                    onClick={() => setShowFamilyModal(false)}
                                    className="text-gray-400 hover:text-gray-600 transition-colors"
                                >
                                    <X size={24} />
                                </button>
                            </div>

                            {/* Contenido del Modal */}
                            <div className="p-6 space-y-4">
                                <div className="grid grid-cols-3 gap-4">
                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-2">
                                            Primer Apellido <span className="text-red-500">*</span>
                                        </label>
                                        <input
                                            type="text"
                                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
                                            value={currentFamily.primerApellido}
                                            onChange={(e) => setCurrentFamily({ ...currentFamily, primerApellido: e.target.value.toUpperCase() })}
                                            placeholder="GARCÍA"
                                        />
                                    </div>
                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-2">
                                            Segundo Apellido
                                        </label>
                                        <input
                                            type="text"
                                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
                                            value={currentFamily.segundoApellido}
                                            onChange={(e) => setCurrentFamily({ ...currentFamily, segundoApellido: e.target.value.toUpperCase() })}
                                            placeholder="PÉREZ"
                                        />
                                    </div>
                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-2">
                                            Nombres <span className="text-red-500">*</span>
                                        </label>
                                        <input
                                            type="text"
                                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
                                            value={currentFamily.nombres}
                                            onChange={(e) => setCurrentFamily({ ...currentFamily, nombres: e.target.value.toUpperCase() })}
                                            placeholder="MARÍA"
                                        />
                                    </div>
                                </div>

                                <div className="grid grid-cols-2 gap-4">
                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-2">
                                            Parentesco <span className="text-red-500">*</span>
                                        </label>
                                        <select
                                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
                                            value={currentFamily.parentesco}
                                            onChange={(e) => setCurrentFamily({ ...currentFamily, parentesco: e.target.value })}
                                        >
                                            <option value="">Seleccionar...</option>
                                            <option value="MADRE">Madre</option>
                                            <option value="PADRE">Padre</option>
                                            <option value="HERMANO/A">Hermano/a</option>
                                            <option value="ABUELO/A">Abuelo/a</option>
                                            <option value="TIO/A">Tío/a</option>
                                            <option value="PRIMO/A">Primo/a</option>
                                            <option value="OTRO">Otro</option>
                                        </select>
                                    </div>

                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-2">
                                            Edad <span className="text-red-500">*</span>
                                        </label>
                                        <input
                                            type="number"
                                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
                                            value={currentFamily.edad}
                                            onChange={(e) => setCurrentFamily({ ...currentFamily, edad: e.target.value })}
                                            placeholder="Ej: 35"
                                            min="0"
                                            max="120"
                                        />
                                    </div>

                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-2">
                                            Sexo <span className="text-red-500">*</span>
                                        </label>
                                        <select
                                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
                                            value={currentFamily.sexo}
                                            onChange={(e) => setCurrentFamily({ ...currentFamily, sexo: e.target.value })}
                                        >
                                            <option value="">Seleccionar...</option>
                                            <option value="MASCULINO">Masculino</option>
                                            <option value="FEMENINO">Femenino</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-2">
                                            Estado Civil
                                        </label>
                                        <select
                                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
                                            value={currentFamily.estadoCivil}
                                            onChange={(e) => setCurrentFamily({ ...currentFamily, estadoCivil: e.target.value })}
                                        >
                                            <option value="">Seleccionar...</option>
                                            <option value="SOLTERO(A)">Soltero(a)</option>
                                            <option value="CASADO(A)">Casado(a)</option>
                                            <option value="CONVIVIENTE">Conviviente</option>
                                            <option value="SEPARADO(A)">Separado(a)</option>
                                            <option value="DIVORCIADO(A)">Divorciado(a)</option>
                                            <option value="VIUDO(A)">Viudo(a)</option>
                                        </select>
                                    </div>

                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-2">
                                            Grado Instrucción
                                        </label>
                                        <select
                                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
                                            value={currentFamily.gradoInstruccion}
                                            onChange={(e) => setCurrentFamily({ ...currentFamily, gradoInstruccion: e.target.value })}
                                        >
                                            <option value="">Seleccionar...</option>
                                            <option value="SIN INSTRUCCIÓN">Sin Instrucción</option>
                                            <option value="INICIAL">Inicial</option>
                                            <option value="PRIMARIA">Primaria</option>
                                            <option value="SECUNDARIA">Secundaria</option>
                                            <option value="TÉCNICA">Técnica</option>
                                            <option value="SUPERIOR">Superior</option>
                                        </select>
                                    </div>
                                </div>

                                <div>
                                    <label className="block text-sm font-bold text-gray-700 mb-2">
                                        Ocupación
                                    </label>
                                    <input
                                        type="text"
                                        className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500"
                                        value={currentFamily.ocupacion}
                                        onChange={(e) => setCurrentFamily({ ...currentFamily, ocupacion: e.target.value })}
                                        placeholder="Ej: Comerciante, Ama de casa, Estudiante..."
                                    />
                                </div>
                            </div>

                            {/* Footer del Modal */}
                            <div className="flex gap-3 justify-end p-6 border-t border-gray-200 bg-gray-50">
                                <button
                                    onClick={() => setShowFamilyModal(false)}
                                    className="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 font-bold hover:bg-gray-100 transition-colors"
                                >
                                    Cancelar
                                </button>
                                <button
                                    onClick={handleSaveFamily}
                                    disabled={!currentFamily.primerApellido || !currentFamily.nombres || !currentFamily.parentesco || !currentFamily.edad || !currentFamily.sexo}
                                    className="px-6 py-2 bg-green-600 text-white rounded-lg font-bold hover:bg-green-700 disabled:bg-gray-300 disabled:cursor-not-allowed transition-colors"
                                >
                                    {editingFamilyIndex !== null ? 'Actualizar' : 'Agregar'}
                                </button>
                            </div>
                        </div>
                    </div>
                )
            }

            {/* MODAL PARA AGREGAR/EDITAR NECESIDAD */}
            {
                showNeedModal && (
                    <div className="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 p-4">
                        <div className="bg-white rounded-xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-y-auto">
                            {/* Header del Modal */}
                            <div className="flex items-center justify-between p-6 border-b border-gray-200">
                                <h3 className="text-xl font-bold text-gray-800">
                                    {editingNeedIndex !== null ? 'Editar Necesidad' : 'Agregar Necesidad'}
                                </h3>
                                <button
                                    onClick={() => setShowNeedModal(false)}
                                    className="text-gray-400 hover:text-gray-600 transition-colors"
                                >
                                    <X size={24} />
                                </button>
                            </div>

                            {/* Contenido del Modal */}
                            <div className="p-6 space-y-4">
                                <div className="grid grid-cols-2 gap-4">
                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-2">
                                            Categoría <span className="text-red-500">*</span>
                                        </label>
                                        <select
                                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500"
                                            value={currentNeed.categoria}
                                            onChange={(e) => setCurrentNeed({ ...currentNeed, categoria: e.target.value })}
                                        >
                                            <option value="">Seleccionar...</option>
                                            <option value="SALUD">Salud</option>
                                            <option value="IDENTIFICACIÓN">Identificación</option>
                                            <option value="ALIMENTACIÓN">Alimentación</option>
                                            <option value="VIVIENDA">Vivienda</option>
                                            <option value="EDUCACIÓN">Educación</option>
                                            <option value="LEGAL">Legal</option>
                                            <option value="PAUTAS DE CRIANZA">Pautas de Crianza</option>
                                            <option value="VIOLENCIA">Violencia</option>
                                            <option value="RECREATIVAS">Recreativas</option>
                                            <option value="OTRA">Otra</option>
                                        </select>
                                    </div>

                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-2">
                                            Descripción <span className="text-red-500">*</span>
                                        </label>
                                        <input
                                            type="text"
                                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500"
                                            value={currentNeed.descripcion}
                                            onChange={(e) => setCurrentNeed({ ...currentNeed, descripcion: e.target.value })}
                                            placeholder="Describa brevemente la necesidad..."
                                        />
                                    </div>
                                </div>

                                <div className="grid grid-cols-3 gap-4">
                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-2">
                                            Fase I - Contacto
                                        </label>
                                        <textarea
                                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500"
                                            rows={4}
                                            value={currentNeed.faseI}
                                            onChange={(e) => setCurrentNeed({ ...currentNeed, faseI: e.target.value })}
                                            placeholder="Acciones a desarrollar en Fase I..."
                                        />
                                    </div>

                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-2">
                                            Fase II - Desarrollo
                                        </label>
                                        <textarea
                                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500"
                                            rows={4}
                                            value={currentNeed.faseII}
                                            onChange={(e) => setCurrentNeed({ ...currentNeed, faseII: e.target.value })}
                                            placeholder="Acciones a desarrollar en Fase II..."
                                        />
                                    </div>

                                    <div>
                                        <label className="block text-sm font-bold text-gray-700 mb-2">
                                            Fase III - Reinserción
                                        </label>
                                        <textarea
                                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500"
                                            rows={4}
                                            value={currentNeed.faseIII}
                                            onChange={(e) => setCurrentNeed({ ...currentNeed, faseIII: e.target.value })}
                                            placeholder="Acciones a desarrollar en Fase III..."
                                        />
                                    </div>
                                </div>
                            </div>

                            {/* Footer del Modal */}
                            <div className="flex gap-3 justify-end p-6 border-t border-gray-200 bg-gray-50">
                                <button
                                    onClick={() => setShowNeedModal(false)}
                                    className="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 font-bold hover:bg-gray-100 transition-colors"
                                >
                                    Cancelar
                                </button>
                                <button
                                    onClick={handleSaveNeed}
                                    disabled={!currentNeed.categoria || !currentNeed.descripcion}
                                    className="px-6 py-2 bg-purple-600 text-white rounded-lg font-bold hover:bg-purple-700 disabled:bg-gray-300 disabled:cursor-not-allowed transition-colors"
                                >
                                    {editingNeedIndex !== null ? 'Actualizar' : 'Agregar'}
                                </button>
                            </div>
                        </div>
                    </div>
                )
            }


            {/* ===== VISTA IMPRESIÓN (OFICIAL) - Solo visible al imprimir ===== */}
            <div className="hidden print:block max-w-[210mm] mx-auto bg-white min-h-[297mm] p-8">

                {/* ENCABEZADO OFICIAL */}
                <table style={{ width: '100%', marginBottom: '5px' }}>
                    <tbody>
                        <tr>
                            <td width="20%"><img src="/logo-min.png" alt="MIMP" style={{ height: '35px', filter: 'grayscale(100%)' }} /></td>
                            <td width="60%" style={{ textAlign: 'center' }}>
                                <h2 style={{ margin: 0, fontSize: '14px', fontWeight: 'bold' }}>FORMATO 4: FICHA DE DIAGNÓSTICO SOCIAL</h2>
                                <p style={{ margin: '2px 0 0 0', fontSize: '11px', color: '#555' }}>EDUCADORES DE CALLE - INABIF</p>
                            </td>
                            <td width="20%" style={{ border: '1px solid black', textAlign: 'center', padding: '5px' }}>
                                <div style={{ fontSize: '9px' }}>FECHA INGRESO</div>
                                <div style={{ fontSize: '12px', fontWeight: 'bold' }}>{formatDate(caso?.fechaIngreso)}</div>
                            </td>
                        </tr>
                    </tbody>
                </table>

                {/* I. DATOS GENERALES */}
                <div style={sectionTitle as any}>I. DATOS GENERALES DEL USUARIO/A</div>
                <table style={tableStyle as any}>
                    <tbody>
                        <tr>
                            <td style={tdStyle} width="20%">
                                <span style={labelStyle as any}>Apellidos</span>
                                <div style={valueStyle as any}>{nna?.apellidoPaterno} {nna?.apellidoMaterno}</div>
                            </td>
                            <td style={tdStyle} width="30%">
                                <span style={labelStyle as any}>Nombres</span>
                                <div style={valueStyle as any}>{nna?.nombres}</div>
                            </td>
                            <td style={tdStyle} width="25%">
                                <span style={labelStyle as any}>Fecha Nacimiento</span>
                                <div style={valueStyle as any}>{formatDate(nna?.fechaNacimiento)}</div>
                            </td>
                            <td style={tdStyle} width="25%">
                                <span style={labelStyle as any}>DNI</span>
                                <div style={valueStyle as any}>{nna?.numeroDoc || 'NO REGISTRA'}</div>
                            </td>
                        </tr>
                        <tr>
                            <td style={tdStyle}>
                                <span style={labelStyle as any}>Sexo</span>
                                M [{nna?.sexo === 'M' ? 'X' : ' '}]  F [{nna?.sexo === 'F' ? 'X' : ' '}]
                            </td>
                            <td style={tdStyle}>
                                <span style={labelStyle as any}>Lugar Nacimiento</span>
                                {nna?.departamentoNac} - {nna?.provinciaNac}
                            </td>
                            <td style={tdStyle} colSpan={2}>
                                <span style={labelStyle as any}>Seguro de Salud</span>
                                {nna?.afiliadoSIS === 'SI' ? 'SIS' : (nna?.afiliadoOtroSeguro === 'SI' ? nna?.detalleOtroSeguro : 'NINGUNO')}
                            </td>
                        </tr>
                        <tr>
                            <td style={tdStyle} colSpan={4}>
                                <span style={labelStyle as any}>Dirección Actual</span>
                                {nna?.domicilioActual}
                            </td>
                        </tr>
                    </tbody>
                </table>

                {/* II. SITUACIÓN DE CALLE */}
                <div style={sectionTitle as any}>II. SITUACIÓN DE CALLE</div>
                <table style={tableStyle as any}>
                    <tbody>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb', fontWeight: 'bold' }} width="25%">Perfil:</td>
                            <td style={tdStyle}><span style={labelStyle as any}>Trabajo Infantil</span> {caso?.perfil === 'TRABAJO_EN_CALLE' ? 'X' : ''}</td>
                            <td style={tdStyle}><span style={labelStyle as any}>Mendicidad</span> {caso?.perfil === 'MENDICIDAD' ? 'X' : ''}</td>
                            <td style={tdStyle}><span style={labelStyle as any}>Vida en Calle</span> {caso?.perfil === 'VIDA_EN_CALLE' ? 'X' : ''}</td>
                        </tr>
                        <tr>
                            <td style={tdStyle}>
                                <span style={labelStyle as any}>Tiempo en Calle</span>
                                <b>{formData.tiempoEnCalle || caso?.tiempoEnCalle}</b>
                            </td>
                            <td style={tdStyle} colSpan={3}>
                                <span style={labelStyle as any}>Punto de Concentración</span>
                                <b>{formData.puntoConcentracion || caso?.zonaIntervencion}</b>
                            </td>
                        </tr>
                        <tr>
                            <td style={tdStyle} colSpan={4}>
                                <span style={labelStyle as any}>Actividad Económica</span>
                                <b>{formData.actividadEconomica || caso?.actividadRealizada}</b>
                            </td>
                        </tr>
                    </tbody>
                </table>

                {/* III. DATOS DEL TUTOR */}
                <div style={sectionTitle as any}>III. DATOS DEL TUTOR / APODERADO / FAMILIAR</div>
                <table style={tableStyle as any}>
                    <tbody>
                        <tr>
                            <td style={tdStyle} width="40%">
                                <span style={labelStyle as any}>Nombres y Apellidos</span>
                                <div style={{ fontWeight: 'bold' }}>{nna?.nombreTutor || '---'}</div>
                            </td>
                            <td style={tdStyle} width="20%">
                                <span style={labelStyle as any}>DNI</span>
                                <b>{formData.tutorDNI || '---'}</b>
                            </td>
                            <td style={tdStyle} width="20%">
                                <span style={labelStyle as any}>Parentesco</span>
                                {nna?.viveCon?.replace(/_/g, ' ') || '---'}
                            </td>
                            <td style={tdStyle} width="20%">
                                <span style={labelStyle as any}>Grado Instrucción</span>
                                <b>{formData.tutorGradoInstruccion || '---'}</b>
                            </td>
                        </tr>
                    </tbody>
                </table>

                {/* IV. DATOS DE LA FAMILIA */}
                <div style={sectionTitle as any}>IV. DATOS DE LA FAMILIA</div>
                <table style={tableStyle as any}>
                    <thead>
                        <tr>
                            <th style={thStyle} width="5%">N°</th>
                            <th style={thStyle} width="35%">Apellidos y Nombres</th>
                            <th style={thStyle} width="15%">Parentesco</th>
                            <th style={thStyle} width="10%">Edad</th>
                            <th style={thStyle} width="10%">Sexo</th>
                            <th style={thStyle} width="15%">G. Instrucción</th>
                            <th style={thStyle} width="10%">Ocupación</th>
                        </tr>
                    </thead>
                    <tbody>
                        {formData.familiares.length > 0 ? (
                            formData.familiares.map((familiar, i) => (
                                <tr key={i}>
                                    <td style={{ ...tdStyle, textAlign: 'center', fontWeight: 'bold' }}>{i + 1}</td>
                                    <td style={tdStyle}>{`${familiar.primerApellido} ${familiar.segundoApellido} ${familiar.nombres}`.trim() || '-'}</td>
                                    <td style={tdStyle}>{familiar.parentesco || '-'}</td>
                                    <td style={{ ...tdStyle, textAlign: 'center' }}>{familiar.edad || '-'}</td>
                                    <td style={tdStyle}>{familiar.sexo || '-'}</td>
                                    <td style={{ ...tdStyle, fontSize: '9px' }}>{familiar.gradoInstruccion || '-'}</td>
                                    <td style={{ ...tdStyle, fontSize: '9px' }}>{familiar.ocupacion || '-'}</td>
                                </tr>
                            ))
                        ) : (
                            // Si no hay familiares, mostrar al menos 3 filas vacías
                            [1, 2, 3].map((i) => (
                                <tr key={i}>
                                    <td style={{ ...tdStyle, textAlign: 'center', fontWeight: 'bold' }}>{i}</td>
                                    <td style={tdStyle}>&nbsp;</td>
                                    <td style={tdStyle}>&nbsp;</td>
                                    <td style={tdStyle}>&nbsp;</td>
                                    <td style={tdStyle}>&nbsp;</td>
                                    <td style={tdStyle}>&nbsp;</td>
                                    <td style={tdStyle}>&nbsp;</td>
                                </tr>
                            ))
                        )}
                    </tbody>
                </table>

                {/* V. DATOS DE LA VIVIENDA */}
                <div style={sectionTitle as any}>V. DATOS DE LA VIVIENDA</div>
                <table style={tableStyle as any}>
                    <tbody>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb' }} width="25%"><b>Material Vivienda:</b></td>
                            <td style={tdStyle}>Concreto [{formData.materialVivienda === 'CONCRETO' ? 'X' : ' '}]</td>
                            <td style={tdStyle}>Precario [{formData.materialVivienda === 'PRECARIO' ? 'X' : ' '}]</td>
                            <td style={tdStyle}>Otro [{formData.materialVivienda === 'OTRO' ? 'X' : ' '}]</td>
                        </tr>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb' }}><b>N° Ambientes:</b></td>
                            <td style={tdStyle}>1 [{formData.numeroAmbientes === '1' ? 'X' : ' '}]</td>
                            <td style={tdStyle}>2 [{formData.numeroAmbientes === '2' ? 'X' : ' '}]</td>
                            <td style={tdStyle}>3+ [{formData.numeroAmbientes === '3+' ? 'X' : ' '}]</td>
                        </tr>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb' }}><b>Propiedad:</b></td>
                            <td style={tdStyle}>Propia [{formData.propiedadVivienda === 'PROPIA' ? 'X' : ' '}]</td>
                            <td style={tdStyle}>Alquilada [{formData.propiedadVivienda === 'ALQUILADA' ? 'X' : ' '}]</td>
                            <td style={tdStyle}>Alojado [{formData.propiedadVivienda === 'ALOJADO' ? 'X' : ' '}]</td>
                        </tr>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb' }}><b>Servicios Básicos:</b></td>
                            <td style={tdStyle}>Agua [{formData.serviciosBasicos.agua ? 'X' : ' '}]</td>
                            <td style={tdStyle}>Luz [{formData.serviciosBasicos.luz ? 'X' : ' '}]</td>
                            <td style={tdStyle}>Desagüe [{formData.serviciosBasicos.desague ? 'X' : ' '}]</td>
                        </tr>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb' }}><b>Estuvo en CAR/Albergue:</b></td>
                            <td style={tdStyle}>SI [{nna?.tieneAntecedenteAlbergue ? 'X' : ' '}]</td>
                            <td style={tdStyle}>NO [{!nna?.tieneAntecedenteAlbergue ? 'X' : ' '}]</td>
                            <td style={tdStyle}>
                                <span style={{ fontSize: '8px' }}>Motivo: {nna?.detalleAntecedenteAlbergue || '---'}</span>
                            </td>
                        </tr>
                    </tbody>
                </table>

                {/* VI. EDUCACIÓN */}
                <div style={sectionTitle as any}>VI. EDUCACIÓN - NNA</div>
                <table style={tableStyle as any}>
                    <tbody>
                        <tr>
                            <td style={tdStyle} width="25%">
                                <span style={labelStyle as any}>¿Estudia Actualmente?</span>
                                <b>{nna?.estudiaActualmente ? 'SÍ' : 'NO'}</b>
                            </td>
                            <td style={tdStyle} width="25%">
                                <span style={labelStyle as any}>Nivel / Grado</span>
                                {nna?.nivelEducativo} - {nna?.gradoEstudio}
                            </td>
                            <td style={tdStyle} width="50%">
                                <span style={labelStyle as any}>Institución Educativa</span>
                                {nna?.institucionEducativa || '---'}
                            </td>
                        </tr>
                        <tr>
                            <td style={tdStyle} colSpan={2}>
                                <span style={labelStyle as any}>Presenta Atraso Escolar</span>
                                SI [{formData.presentaAtraso ? 'X' : ' '}] NO [{!formData.presentaAtraso ? 'X' : ' '}]
                                <b> Cuánto: {formData.tiempoAtraso || '---'}</b>
                            </td>
                            <td style={tdStyle}>
                                <span style={labelStyle as any}>Motivo Atraso</span>
                                {formData.motivoAtraso || '---'}
                            </td>
                        </tr>
                        <tr>
                            <td style={tdStyle}>
                                <span style={labelStyle as any}>Problemas Aprendizaje</span>
                                SI [{formData.problemasAprendizaje ? 'X' : ' '}] NO [{!formData.problemasAprendizaje ? 'X' : ' '}]
                            </td>
                            <td style={tdStyle}>
                                <span style={labelStyle as any}>Problemas Conducta</span>
                                SI [{formData.problemasConducta ? 'X' : ' '}] NO [{!formData.problemasConducta ? 'X' : ' '}]
                            </td>
                            <td style={tdStyle}>
                                <span style={labelStyle as any}>Ha sido expulsado</span>
                                SI [{formData.expulsado ? 'X' : ' '}] NO [{!formData.expulsado ? 'X' : ' '}] N° veces: {formData.vecesExpulsado || '---'}
                            </td>
                        </tr>
                    </tbody>
                </table>

                {/* VII. SALUD */}
                <div style={sectionTitle as any}>VII. SALUD – ALIMENTACIÓN – HIGIENE</div>
                <table style={tableStyle as any}>
                    <tbody>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb' }} width="30%"><b>Enfermedad Crónica:</b></td>
                            <td style={tdStyle}>SI [{formData.enfermedadCronica ? 'X' : ' '}] NO [{!formData.enfermedadCronica ? 'X' : ' '}]</td>
                            <td style={tdStyle}>{formData.detalleEnfermedadCronica || '---'}</td>
                        </tr>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb' }}><b>Discapacidad:</b></td>
                            <td style={tdStyle}>SI [{nna?.tieneDiscapacidad ? 'X' : ' '}] NO [{!nna?.tieneDiscapacidad ? 'X' : ' '}]</td>
                            <td style={tdStyle}>{nna?.tipoDiscapacidad || '---'}</td>
                        </tr>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb' }}><b>Problemas Psicológicos:</b></td>
                            <td style={tdStyle}>SI [{formData.problemaPsicologico ? 'X' : ' '}] NO [{!formData.problemaPsicologico ? 'X' : ' '}]</td>
                            <td style={tdStyle}>{formData.detalleProblemaPsicologico || '---'}</td>
                        </tr>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb' }}><b>Consume Sustancias:</b></td>
                            <td style={tdStyle}>SI [{formData.consumeSustancias ? 'X' : ' '}] NO [{!formData.consumeSustancias ? 'X' : ' '}]</td>
                            <td style={tdStyle}>{formData.tipoSustancias || '---'}</td>
                        </tr>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb' }}><b>Recibe 3 Alimentos al Día:</b></td>
                            <td style={tdStyle}>SI [{formData.recibeTresAlimentos ? 'X' : ' '}] NO [{!formData.recibeTresAlimentos ? 'X' : ' '}]</td>
                            <td style={tdStyle}></td>
                        </tr>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb' }}><b>Higiene Personal Adecuada:</b></td>
                            <td style={tdStyle}>SI [{formData.higieneAdecuada ? 'X' : ' '}] NO [{!formData.higieneAdecuada ? 'X' : ' '}]</td>
                            <td style={tdStyle}><span style={{ fontSize: '8px' }}>Cabello/uñas limpias y recortadas</span></td>
                        </tr>
                    </tbody>
                </table>

                {/* VIII. RECREACIÓN */}
                <div style={sectionTitle as any}>VIII. RECREACIÓN E INTERESES DEL NNA</div>
                <table style={tableStyle as any}>
                    <tbody>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb' }} width="30%"><b>Cuenta con Tiempo para Jugar:</b></td>
                            <td style={tdStyle} width="20%">SI [{formData.tiempoParaJugar ? 'X' : ' '}] NO [{!formData.tiempoParaJugar ? 'X' : ' '}]</td>
                            <td style={tdStyle} width="25%">
                                <span style={labelStyle as any}>Veces/Semana</span>
                                <b>{formData.vecesJuegaSemana || '---'}</b>
                            </td>
                            <td style={tdStyle} width="25%">
                                <span style={labelStyle as any}>Lugar</span>
                                <b>{formData.lugarJuego || '---'}</b>
                            </td>
                        </tr>
                        <tr>
                            <td style={{ ...tdStyle, backgroundColor: '#f9fafb' }}><b>Participa en Institución:</b></td>
                            <td style={tdStyle}>SI [{formData.participaInstitucion ? 'X' : ' '}] NO [{!formData.participaInstitucion ? 'X' : ' '}]</td>
                            <td style={tdStyle} colSpan={2}>
                                <span style={labelStyle as any}>Tipo</span>
                                {formData.tipoInstitucion || '---'}
                            </td>
                        </tr>
                        <tr>
                            <td style={tdStyle}><span style={labelStyle as any}>Intereses Deportivos</span> SI [{formData.interesesDeportivos ? 'X' : ' '}] NO [{!formData.interesesDeportivos ? 'X' : ' '}]</td>
                            <td style={tdStyle}><span style={labelStyle as any}>Intereses Artísticos</span> SI [{formData.interesesArtisticos ? 'X' : ' '}] NO [{!formData.interesesArtisticos ? 'X' : ' '}]</td>
                            <td style={tdStyle} colSpan={2}><span style={labelStyle as any}>Actividades con Familia</span> SI [{formData.actividadesFamilia ? 'X' : ' '}] NO [{!formData.actividadesFamilia ? 'X' : ' '}]</td>
                        </tr>
                    </tbody>
                </table>

                {/* IX. NECESIDADES Y PLAN DE ACCIÓN */}
                <div style={sectionTitle as any}>IX. NECESIDADES DEL NNA Y PLAN DE ACCIÓN</div>
                <table style={tableStyle as any}>
                    <thead>
                        <tr>
                            <th style={thStyle} width="5%">N°</th>
                            <th style={thStyle} width="15%">Categoría</th>
                            <th style={thStyle} width="20%">Descripción</th>
                            <th style={thStyle} width="20%">Fase I (Contacto)</th>
                            <th style={thStyle} width="20%">Fase II (Desarrollo)</th>
                            <th style={thStyle} width="20%">Fase III (Reinserción)</th>
                        </tr>
                    </thead>
                    <tbody>
                        {formData.necesidades.length > 0 ? (
                            formData.necesidades.map((necesidad, idx) => (
                                <tr key={idx}>
                                    <td style={{ ...tdStyle, textAlign: 'center', fontWeight: 'bold' }}>{idx + 1}</td>
                                    <td style={{ ...tdStyle, fontSize: '9px', fontWeight: 'bold' }}>{necesidad.categoria}</td>
                                    <td style={{ ...tdStyle, fontSize: '9px' }}>{necesidad.descripcion}</td>
                                    <td style={{ ...tdStyle, fontSize: '8px' }}>{necesidad.faseI || '-'}</td>
                                    <td style={{ ...tdStyle, fontSize: '8px' }}>{necesidad.faseII || '-'}</td>
                                    <td style={{ ...tdStyle, fontSize: '8px' }}>{necesidad.faseIII || '-'}</td>
                                </tr>
                            ))
                        ) : (
                            // Si no hay necesidades, mostrar al menos 3 filas vacías
                            [1, 2, 3].map((i) => (
                                <tr key={i}>
                                    <td style={{ ...tdStyle, textAlign: 'center', fontWeight: 'bold' }}>{i}</td>
                                    <td style={tdStyle}>&nbsp;</td>
                                    <td style={tdStyle}>&nbsp;</td>
                                    <td style={tdStyle}>&nbsp;</td>
                                    <td style={tdStyle}>&nbsp;</td>
                                    <td style={tdStyle}>&nbsp;</td>
                                </tr>
                            ))
                        )}
                    </tbody>
                </table>

                {/* FIRMAS */}
                <table style={{ width: '100%', marginTop: '40px', borderCollapse: 'collapse' }}>
                    <tbody>
                        <tr>
                            <td style={{ padding: '8px 0', fontSize: '10px' }}>
                                <b>Educador/a Responsable:</b> {caso?.responsable?.nombreCompleto || '________________________________'}
                            </td>
                        </tr>
                        <tr>
                            <td style={{ padding: '4px 0', fontSize: '10px' }}>
                                <b>DNI:</b> {caso?.responsable?.dni || '________________'}
                            </td>
                        </tr>
                        <tr>
                            <td style={{ padding: '4px 0', fontSize: '10px' }}>
                                <b>Fecha:</b> {new Date().toLocaleDateString()} - <b>Zona:</b> {caso?.zonaIntervencion || '________________'}
                            </td>
                        </tr>
                        <tr>
                            <td style={{ paddingTop: '30px' }}>
                                <div style={{ borderTop: '1px solid black', width: '250px', paddingTop: '5px', textAlign: 'center', fontSize: '10px', fontWeight: 'bold' }}>
                                    FIRMA DEL EDUCADOR
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>

            </div>
        </div >
    );
};
