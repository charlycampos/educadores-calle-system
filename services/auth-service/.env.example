# auth-service — Variables de entorno
# Copiar a .env y ajustar valores

PORT=3001

# ── Oracle DB (OGTI) ─────────────────────────────────────────
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_USER=sec_user
